        .info-card-role-4 .info-highlight,
        .info-card-role-5 .info-highlight,
        .info-card-role-6 .info-highlight { 
            border-left-color: #5cc87b; 
            background: rgba(92, 200, 123, 0.1); 
        }
    </style>
}
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/notificaciones.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    
    <!-- Datos del dashboard en formato JSON (opcional, si los necesitas) -->
    @if (ViewBag.DashboardData != null)
    {
        <script id="dashboard-data" type="application/json">
            @Html.Raw(Json.Serialize(ViewBag.DashboardData))
        </script>
    }
}