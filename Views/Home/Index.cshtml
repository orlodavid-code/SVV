    <!--  SOLICITUDES RECIENTES (PARA ROLES QUE TIENEN SUS PROPIAS SOLICITUDES) -->
    @if (rolId == 1) // EMPLEADO - SOLICITUDES PROPIAS
    {
        <h4 class="section-title">Tus Solicitudes Recientes</h4>
        <div class="row">
            <div class="col-12 mb-5">
                <div class="solicitud-card">
                    <div class="solicitud-card-body">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0 text-white"><i class="fas fa-history me-2"></i>Actividad Reciente</h5>
                            <a asp-controller="Solicitudes" asp-action="Index" class="btn btn-solicitud-outline btn-sm">
                                <i class="fas fa-list me-1"></i> Ver Todas
                            </a>
                        </div>

                        @if (solicitudesRecientes != null && solicitudesRecientes.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-dark table-hover table-striped">
                                    <thead class="table-header-custom">
                                        <tr>
                                            <th class="border-0">Código</th>
                                            <th class="border-0">Destino</th>
                                            <th class="border-0">Fechas</th>
                                            <th class="border-0">Estado</th>
                                            <th class="border-0 text-center">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (SolicitudesViaje solicitud in solicitudesRecientes)
                                        {
                                            var totalAnticipos = solicitud.Anticipos?.Sum(a => a.MontoSolicitado) ?? 0;
                                            <tr class="table-row-custom">
                                                <td>
                                                    <strong class="text-accent">@solicitud.CodigoSolicitud</strong>
                                                </td>
                                                <td class="text-white">@solicitud.Destino</td>
                                                <td>
                                                    <small class="text-muted">@solicitud.FechaSalida.ToString("dd/MM/yyyy") - @solicitud.FechaRegreso.ToString("dd/MM/yyyy")</small>
                                                </td>
                                                <td>
                                                    @if (solicitud.Estado?.Codigo == "BORRADOR")
                                                    {
                                                        <span class="badge bg-secondary">@solicitud.Estado.Codigo</span>
                                                    }
                                                    else if (solicitud.Estado?.Codigo == "ENVIADA_JP")
                                                    {
                                                        <span class="badge bg-warning text-dark">@solicitud.Estado.Codigo</span>
                                                    }
                                                    else if (solicitud.Estado?.Codigo != null && solicitud.Estado.Codigo.Contains("APROBADA"))
                                                    {
                                                        <span class="badge bg-success">@solicitud.Estado.Codigo</span>
                                                    }
                                                    else if (solicitud.Estado?.Codigo == "RECHAZADA")
                                                    {
                                                        <span class="badge bg-danger">@solicitud.Estado.Codigo</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-info">@solicitud.Estado?.Codigo</span>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a asp-controller="Solicitudes" asp-action="Detalles" asp-route-id="@solicitud.Id"
                                                           class="btn btn-outline-info btn-action" title="Ver detalles">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        @if (solicitud.EstadoId == 1) // BORRADOR
                                                        {
                                                            <a asp-controller="Solicitudes" asp-action="Editar" asp-route-id="@solicitud.Id"
                                                               class="btn btn-outline-warning btn-action" title="Editar">
                                                                <i class="fas fa-edit"></i>
                                                            </a>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-folder-open fa-4x text-muted mb-3"></i>
                                <h5 class="text-muted mb-2">No tienes solicitudes recientes</h5>
                                <p class="text-muted mb-3">Comienza creando tu primera solicitud de viáticos</p>
                                <a asp-controller="Solicitudes" asp-action="CrearSolicitud" class="btn btn-primary">
                                    <i class="fas fa-plus me-2"></i>Crear Primera Solicitud
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!--  PENDIENTES DE APROBACIÓN (PARA ROLES CON PERMISOS DE APROBACIÓN) -->
    @if (rolId == 6 || rolId == 5 || rolId == 4 || rolId == 2) // Admin, Dirección, Finanzas, JP
    {
        <h4 class="section-title">Pendientes de Aprobación</h4>
        <div class="row">
            <div class="col-12 mb-5">
                <div class="solicitud-card">
                    <div class="solicitud-card-body">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0 text-white"><i class="fas fa-list-alt me-2"></i> Solicitudes que Requieren su Acción</h5>
                            <a asp-controller="Aprobaciones" asp-action="Pendientes" class="btn btn-solicitud-outline btn-sm">
                                <i class="fas fa-external-link-alt me-2"></i>Ver Todas
                            </a>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-dark table-hover table-striped">
                                <thead class="table-header-custom">
                                    <tr>
                                        <th class="border-0">Código</th>
                                        <th class="border-0">Empleado</th>
                                        <th class="border-0">Proyecto</th>
                                        <th class="border-0">Destino</th>
                                        <th class="border-0">Monto Sol.</th>
                                        <th class="border-0">Estado</th>
                                        <th class="border-0 text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (solicitudesPendientes != null && solicitudesPendientes.Any())
                                    {
                                        @foreach (var solicitud in solicitudesPendientes)
                                        {
                                            <tr class="table-row-custom">
                                                <td><strong class="text-accent">@solicitud.Codigo</strong></td>
                                                <td class="text-white">@solicitud.EmpleadoNombre</td>
                                                <td class="text-white">@solicitud.NombreProyecto</td>
                                                <td class="text-white">@solicitud.Destino</td>
                                                <td class="text-white">@solicitud.MontoSolicitado</td>
                                                <td><span class="status-badge @solicitud.EstadoCssClass">@solicitud.EstadoNombre</span></td>
                                                <td class="text-center">
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a asp-controller="Aprobaciones" asp-action="Detalles" asp-route-id="@solicitud.IdSolicitud"
                                                           class="btn btn-outline-info btn-action" title="Revisar">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">
                                                <i class="fas fa-check-circle me-2"></i> ¡Genial! No hay solicitudes pendientes de aprobación.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!--  COMPROBACIONES PENDIENTES DE REVISIÓN JP (SOLO PARA ROL 2) -->
    @if (rolId == 2)
    {
        <h4 class="section-title">Comprobaciones Pendientes de Revisión</h4>
        <div class="row">
            <div class="col-12 mb-5">
                <div class="solicitud-card">
                    <div class="solicitud-card-body">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0 text-white"><i class="fas fa-clipboard-check me-2"></i> Comprobaciones para Revisión de Actividades</h5>
                            <a asp-controller="Finanzas" asp-action="RevisionActividadesJP" class="btn btn-solicitud-outline btn-sm">
                                <i class="fas fa-external-link-alt me-2"></i>Ver Todas
                            </a>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-dark table-hover table-striped">
                                <thead class="table-header-custom">
                                    <tr>
                                        <th class="border-0">Código Comprobación</th>
                                        <th class="border-0">Empleado</th>
                                        <th class="border-0">Destino</th>
                                        <th class="border-0">Total Gastos</th>
                                        <th class="border-0">Total Anticipo</th>
                                        <th class="border-0">Diferencia</th>
                                        <th class="border-0 text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (comprobacionesPendientesRevisionJP != null && comprobacionesPendientesRevisionJP.Any())
                                    {
                                        @foreach (var comprobacion in comprobacionesPendientesRevisionJP)
                                        {
                                            <tr class="table-row-custom">
                                                <td><strong class="text-accent">@comprobacion.CodigoComprobacion</strong></td>
                                                <td class="text-white">@(comprobacion.SolicitudViaje?.Empleado?.Nombre ?? "N/A") @(comprobacion.SolicitudViaje?.Empleado?.Apellidos ?? "")</td>
                                                <td class="text-white">@(comprobacion.SolicitudViaje?.Destino ?? "N/A")</td>
                                                <td class="text-white">@(comprobacion.TotalGastosComprobados?.ToString("C") ?? "$0")</td>
                                                <td class="text-white">@(comprobacion.TotalAnticipo?.ToString("C") ?? "$0")</td>
                                                <td>
                                                    @{
                                                        var diferencia = (comprobacion.TotalAnticipo ?? 0) - (comprobacion.TotalGastosComprobados ?? 0);
                                                        var diferenciaClass = diferencia >= 0 ? "text-success" : "text-danger";
                                                        var diferenciaIcon = diferencia >= 0 ? "fas fa-arrow-up" : "fas fa-arrow-down";
                                                    }
                                                    <span class="@diferenciaClass">
                                                        <i class="@diferenciaIcon me-1"></i>
                                                        @Math.Abs(diferencia).ToString("C")
                                                        @if (diferencia >= 0)
                                                        {
                                                            <span class="badge bg-info ms-2">A FAVOR</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-warning text-dark ms-2">EN CONTRA</span>
                                                        }
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a asp-controller="Finanzas" asp-action="RevisionActividadesJP"
                                                           class="btn btn-outline-info btn-action" title="Revisar">
                                                            <i class="fas fa-eye"></i> Revisar
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">
                                                <i class="fas fa-check-circle me-2"></i> ¡Genial! No hay comprobaciones pendientes de revisión.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

