@using System.Security.Claims;
@using SVV.Models;
@using SVV.ViewModels;

@{
    ViewData["Title"] = "Dashboard - " + ViewBag.RolNombre;
    var solicitudesPendientes = ViewBag.SolicitudesPendientes as List<SolicitudDashboardViewModel> ?? new List<SolicitudDashboardViewModel>();
    var rolId = (int?)ViewBag.RolId;

    //  Variables para diferentes tipos de solicitudes pendientes - CON VALORES POR DEFECTO
    var solicitudesPendientesJP = ViewBag.SolicitudesPendientesJP as List<SolicitudesViaje> ?? new List<SolicitudesViaje>();
    var solicitudesPendientesRH = ViewBag.SolicitudesPendientesRH as List<SolicitudesViaje> ?? new List<SolicitudesViaje>();
    var comprobacionesPendientesRevisionJP = ViewBag.ComprobacionesPendientesRevisionJP as List<ComprobacionesViaje> ?? new List<ComprobacionesViaje>();
    
    //  Variable para solicitudes recientes de empleado
    var solicitudesRecientes = ViewBag.SolicitudesRecientes as List<SolicitudesViaje> ?? new List<SolicitudesViaje>();
    
    //  Funciones helper para formatear valores
    string FormatCurrency(decimal? value)
    {
        if (value == null) return "$0.00";
        return value.Value.ToString("C");
    }
    
    decimal GetDecimalValue(decimal? value) => value ?? 0;
}
<div class="dashboard-container">
    <div class="dashboard-header">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="dashboard-title">
                    ¡Hola de nuevo, <span class="user-name">@ViewBag.NombreUsuario</span>!
                </h1>
                <p class="dashboard-subtitle">Resumen de Viáticos y Actividad del Sistema.</p>
            </div>
            <div class="col-md-6 text-md-end text-start">
                <span class="badge bg-viamtek me-2">@ViewBag.RolNombre</span>
                <span class="user-email d-block d-md-inline-block text-secondary">@User.Identity.Name</span>
            </div>
        </div>
    </div>

    <!-- Alertas (ahora manejadas por SweetAlert) -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show d-none" role="alert" data-sweet-alert="success">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show d-none" role="alert" data-sweet-alert="error">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        </div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show d-none" role="alert" data-sweet-alert="warning">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Warning"]
        </div>
    }

    <!--  ESTADÍSTICAS ESPECÍFICAS POR ROL -->
    @if (rolId == 1) // EMPLEADO
    {
        <h4 class="section-title">Tu Resumen de Viáticos</h4>
        <div class="row">
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card primary">
                    <div class="stats-icon"><i class="fas fa-edit"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.MisSolicitudesBorrador ?? 0)</h3>
                        <p>En Borrador</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card warning">
                    <div class="stats-icon"><i class="fas fa-clock"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.MisSolicitudesPendientes ?? 0)</h3>
                        <p>Pendientes</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card success">
                    <div class="stats-icon"><i class="fas fa-check-circle"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.MisSolicitudesAprobadas ?? 0)</h3>
                        <p>Aprobadas</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card danger">
                    <div class="stats-icon"><i class="fas fa-times-circle"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.MisSolicitudesRechazadas ?? 0)</h3>
                        <p>Rechazadas</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-12 col-md-12 mb-4">
                <div class="stats-card secondary">
                    <div class="stats-icon"><i class="fas fa-hand-holding-usd"></i></div>
                    <div class="stats-content">
                        <h3>@((ViewBag.TotalAnticiposAutorizados ?? 0).ToString("C"))</h3>
                        <p>Anticipos Autorizados</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (rolId == 2) // JEFE PROYECTO
    {
        <h4 class="section-title">Panel de Jefe de Proceso/Proyecto</h4>
        <div class="row">
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="stats-card warning">
                    <div class="stats-icon"><i class="fas fa-clock"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.PendientesJP ?? 0)</h3>
                        <p>Solicitudes Pendientes</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="stats-card success">
                    <div class="stats-icon"><i class="fas fa-check-circle"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.AprobadasJP ?? 0)</h3>
                        <p>Solicitudes Aprobadas</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="stats-card info">
                    <div class="stats-icon"><i class="fas fa-clipboard-check"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.ComprobacionesPendientesRevision ?? 0)</h3>
                        <p>Comprobaciones para Revisión</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (rolId == 3) // RECURSOS HUMANOS
    {
        <h4 class="section-title">Panel de Capital Humano</h4>
        <div class="row">
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="stats-card primary">
                    <div class="stats-icon"><i class="fas fa-plane"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.TotalSolicitudesActivas ?? 0)</h3>
                        <p>Solicitudes Activas</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="stats-card success">
                    <div class="stats-icon"><i class="fas fa-check-circle"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.SolicitudesAprobadasDireccion ?? 0)</h3>
                        <p>Solicitudes Aprobadas por Dirección</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="stats-card secondary">
                    <div class="stats-icon"><i class="fas fa-edit"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.SolicitudesBorradorOtros ?? 0)</h3>
                        <p>Borrador de Otros Empleados</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (rolId == 4) // FINANZAS
    {
        <h4 class="section-title">Panel de Finanzas</h4>
        <div class="row">
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card primary">
                    <div class="stats-icon"><i class="fas fa-plane"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.SolicitudesActivas ?? 0)</h3>
                        <p>Solicitudes Activas</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card warning">
                    <div class="stats-icon"><i class="fas fa-clock"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.PendientesFinanzas ?? 0)</h3>
                        <p>Pendientes de Aprobación</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card danger">
                    <div class="stats-icon"><i class="fas fa-money-bill-wave"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.PendientesPorSaldar ?? 0)</h3>
                        <p>Pendientes por Saldar</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card success">
                    <div class="stats-icon"><i class="fas fa-hand-holding-usd"></i></div>
                    <div class="stats-content">
                        <h3>@((ViewBag.AnticiposAutorizadosPorUsuario ?? 0).ToString("C"))</h3>
                        <p>Anticipos Autorizados por Mí</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (rolId == 5) // DIRECCIÓN
    {
        <h4 class="section-title">Panel de Dirección General</h4>
        <div class="row">
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="stats-card primary">
                    <div class="stats-icon"><i class="fas fa-plane"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.SolicitudesActivas ?? 0)</h3>
                        <p>Solicitudes Activas</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="stats-card warning">
                    <div class="stats-icon"><i class="fas fa-clock"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.PendientesDireccion ?? 0)</h3>
                        <p>Pendientes de Aprobación</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="stats-card info">
                    <div class="stats-icon"><i class="fas fa-dollar-sign"></i></div>
                    <div class="stats-content">
                        <h3>@((ViewBag.AnticiposAutorizados ?? 0).ToString("C"))</h3>
                        <p>Anticipos Totales Autorizados</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (rolId == 6) // ADMIN
    {
        <h4 class="section-title">Panel de Administración</h4>
        <div class="row">
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card primary">
                    <div class="stats-icon"><i class="fas fa-plane"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.SolicitudesActivas ?? 0)</h3>
                        <p>Solicitudes Activas</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card warning">
                    <div class="stats-icon"><i class="fas fa-clock"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.PendientesAprobacion ?? 0)</h3>
                        <p>Pendientes de Aprobación</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card success">
                    <div class="stats-icon"><i class="fas fa-users"></i></div>
                    <div class="stats-content">
                        <h3>@(ViewBag.TotalUsuariosActivos ?? 0)</h3>
                        <p>Usuarios Activos</p>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="stats-card info">
                    <div class="stats-icon"><i class="fas fa-dollar-sign"></i></div>
                    <div class="stats-content">
                        <h3>@((ViewBag.AnticiposTotalesAutorizados ?? 0).ToString("C"))</h3>
                        <p>Anticipos Totales</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <!--  ACCIONES UNIVERSALES PARA TODOS LOS ROLES -->
    <h4 class="section-title">Gestiona Tus Viáticos</h4>
    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="quick-actions-card h-100">
                <h4 class="card-title"><i class="fas fa-bolt me-2"></i> Acciones Rápidas</h4>
                <div class="row">
                    <!--  ACCIONES UNIVERSALES PARA TODOS -->
                    <div class="col-4 mb-3">
                        <a asp-controller="Solicitudes" asp-action="CrearSolicitud" class="quick-action-btn" data-bs-toggle="tooltip">
                            <div class="action-icon">
                                <i class="fas fa-plus"></i>
                            </div>
                            <span class="action-text">Crear Solicitud</span>
                        </a>
                    </div>
                    <div class="col-4 mb-3">
                        <a asp-controller="Solicitudes" asp-action="Index" class="quick-action-btn" data-bs-toggle="tooltip">
                            <div class="action-icon">
                                <i class="fas fa-list"></i>
                            </div>
                            <span class="action-text">Mis Solicitudes</span>
                        </a>
                    </div>
                    <div class="col-4 mb-3">
                        <a asp-controller="Comprobaciones" asp-action="Index" class="quick-action-btn" data-bs-toggle="tooltip">
                            <div class="action-icon">
                                <i class="fas fa-receipt"></i>
                            </div>
                            <span class="action-text">Comprobar Gastos</span>
                        </a>
                    </div>

                    <!--  ACCIONES ESPECÍFICAS POR ROL -->
                    @if (rolId == 6 || rolId == 5 || rolId == 4) // Admin, Dirección, Finanzas
                    {
                        @if (rolId == 4) // Finanzas
                        {
                            <div class="col-4 mb-3">
                                <a asp-controller="Finanzas" asp-action="Cotizaciones" class="quick-action-btn" data-bs-toggle="tooltip">
                                    <div class="action-icon">
                                        <i class="fas fa-file-invoice-dollar"></i>
                                    </div>
                                    <span class="action-text">Cotizaciones</span>
                                </a>
                            </div>
                            <div class="col-4 mb-3">
                                <a asp-controller="Finanzas" asp-action="Facturas" class="quick-action-btn" data-bs-toggle="tooltip">
                                    <div class="action-icon">
                                        <i class="fas fa-receipt"></i>
                                    </div>
                                    <span class="action-text">Revisión Facturas</span>
                                </a>
                            </div>
                            <div class="col-4 mb-3">
                                <a asp-controller="Finanzas" asp-action="AutorizacionesPago" class="quick-action-btn" data-bs-toggle="tooltip">
                                    <div class="action-icon">
                                        <i class="fas fa-money-check"></i>
                                    </div>
                                    <span class="action-text">Autorizar Pagos</span>
                                </a>
                            </div>
                             <div class="col-4 mb-3">
                                <a asp-controller="Admin" asp-action="Empleados" class="quick-action-btn" data-bs-toggle="tooltip">
                                    <div class="action-icon">
                                        <i class="fas fa-user-tie"></i>
                                    </div>
                                    <span class="action-text">Gestionar Personal</span>
                                </a>
                            </div>
                        }

                        @if (rolId == 6) // Solo Admin
                        {
                            <div class="col-4 mb-3">
                                <a asp-controller="Admin" asp-action="Empleados" class="quick-action-btn" data-bs-toggle="tooltip">
                                    <div class="action-icon">
                                        <i class="fas fa-user-tie"></i>
                                    </div>
                                    <span class="action-text">Gestionar Personal</span>
                                </a>
                            </div>
                        }

                        <div class="col-4 mb-3">
                            <a asp-controller="Finanzas" asp-action="Reportes" class="quick-action-btn" data-bs-toggle="tooltip">
                                <div class="action-icon">
                                    <i class="fas fa-chart-bar"></i>
                                </div>
                                <span class="action-text">Reportes</span>
                            </a>
                        </div>
                        <div class="col-4 mb-3">
                            <a asp-controller="Aprobaciones" asp-action="Pendientes" class="quick-action-btn" data-bs-toggle="tooltip">
                                <div class="action-icon">
                                    <i class="fas fa-tasks"></i>
                                </div>
                                <span class="action-text">Solicitudes Pendientes</span>
                            </a>
                        </div>
                    }
                    else if (rolId == 2) // Jefe Proyecto
                    {
                        <div class="col-4 mb-3">
                            <a asp-controller="Aprobaciones" asp-action="Pendientes" class="quick-action-btn" data-bs-toggle="tooltip">
                                <div class="action-icon">
                                    <i class="fas fa-tasks"></i>
                                </div>
                                <span class="action-text">Solicitudes Pendientes</span>
                            </a>
                        </div>
                        <div class="col-4 mb-3">
                            <a asp-controller="Finanzas" asp-action="RevisionActividadesJP" class="quick-action-btn" data-bs-toggle="tooltip">
                                <div class="action-icon">
                                    <i class="fas fa-clipboard-check"></i>
                                </div>
                                <span class="action-text">Revisar Actividades</span>
                            </a>
                        </div>
                    }
                    else if (rolId == 3) // RH - CAPITAL HUMANO
                    {
                        <div class="col-4 mb-3">
                            <a asp-controller="Aprobaciones" asp-action="Pendientes" class="quick-action-btn" data-bs-toggle="tooltip">
                                <div class="action-icon">
                                    <i class="fas fa-tasks"></i>
                                </div>
                                <span class="action-text">Ver Todas Solicitudes</span>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!--  INFORMACIÓN IMPORTANTE ESPECÍFICA POR ROL -->
        <div class="col-lg-6 mb-4">
            <div class="info-card info-card-role-@rolId">
                <div class="info-card-header">
                    <h4 class="info-card-title">
                        <i class="fas fa-info-circle"></i> Información Importante
                    </h4>
                </div>
                <div class="info-card-body">
                    @if (rolId == 1) // EMPLEADO
                    {
                        <ul class="info-list">
                            <li>
                                <i class="fas fa-check-circle info-icon"></i>
                                <span class="info-text">Crea solicitudes de viáticos para tus viajes de trabajo</span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle info-icon"></i>
                                <span class="info-text">Tus solicitudes pasan por: <strong> tu Jefe Directo → Capital Humano → Finanzas → Dirección</strong></span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle info-icon"></i>
                                <span class="info-text">Comprueba tus gastos después de cada viaje dentro del plazo establecido</span>
                            </li>
                            <li>
                                <i class="fas fa-exclamation-triangle info-icon"></i>
                                <span class="info-text"><strong>Plazos importantes:</strong> Solicitud 3 días antes | Comprobación hasta 5 días después</span>
                            </li>
                            <li>
                                <i class="fas fa-exclamation-triangle info-icon"></i>
                                <span class="info-text"><strong>Facturas:</strong> A nombre de CUVITEK Software con RFC correcto</span>
                            </li>
                        </ul>
                        
                        <div class="info-highlight">
                            <div class="info-highlight-title">
                                <i class="fas fa-lightbulb me-2"></i>Consejo Rápido
                            </div>
                            <p class="info-highlight-text">
                                Mantén todos tus comprobantes originales. Las facturas deben incluir RFC, dirección fiscal y desglose de IVA.
                            </p>
                        </div>
                    }
                    else if (rolId == 2) // JEFE PROYECTO
                    {
                        <ul class="info-list">
                            <li>
                                <i class="fas fa-check-circle info-icon"></i>
                                <span class="info-text">Aprueba solicitudes de viáticos de tus empleados directos</span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle info-icon"></i>
                                <span class="info-text">Revisa actividades y comprobaciones de viajes de tu equipo</span>
                            </li>
                            <li>
                                <i class="fas fa-exclamation-triangle info-icon"></i>
                                <span class="info-text"><strong>Plazo de revisión:</strong> 24 horas hábiles máximo por solicitud</span>
                            </li>
                            <li>
                                <i class="fas fa-exclamation-triangle info-icon"></i>
                                <span class="info-text">Verifica que las actividades coincidan con el proyecto asignado</span>
                            </li>
                            <li>
                                <i class="fas fa-info-circle info-icon"></i>
                                <span class="info-text">Tus aprobaciones son el <strong>primer filtro</strong> del proceso de viáticos</span>
                            </li>
                        </ul>
                        
                        <div class="info-highlight">
                            <div class="info-highlight-title">
                                <i class="fas fa-lightbulb me-2"></i>Consejo Rápido
                            </div>
                            <p class="info-highlight-text">
                                Revisa cuidadosamente que los montos solicitados sean acordes al destino y duración del viaje.
                            </p>
                        </div>
                    }
                    else if (rolId == 3) // RECURSOS HUMANOS
                    {
                        <ul class="info-list">
                            <li>
                                <i class="fas fa-check-circle info-icon"></i>
                                <span class="info-text">Visualiza todas las solicitudes de viáticos de la empresa</span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle info-icon"></i>
                                <span class="info-text">Monitorea el proceso de aprobación completo de principio a fin</span>
                            </li>
                            <li>
                                <i class="fas fa-exclamation-triangle info-icon"></i>
                                <span class="info-text"><strong>No puedes:</strong> Gestionar empleados (solo Finanzas tiene este permiso)</span>
                            </li>
                            <li>
                                <i class="fas fa-info-circle info-icon"></i>
                                <span class="info-text">Tu rol es de <strong>supervisión y seguimiento</strong> del proceso</span>
                            </li>
                            <li>
                                <i class="fas fa-info-circle info-icon"></i>
                                <span class="info-text">Reporta inconsistencias directamente a Dirección o Finanzas</span>
                            </li>
                        </ul>
                        
                        <div class="info-highlight">
                            <div class="info-highlight-title">
                                <i class="fas fa-lightbulb me-2"></i>Consejo Rápido
                            </div>
                            <p class="info-highlight-text">
                                Utiliza la vista de todas las solicitudes para identificar días fuera de oficina.
                            </p>
                        </div>
                    }
                    else if (rolId == 4) // FINANZAS
                    {
                        <ul class="info-list">
                            <li>
                                <i class="fas fa-check-circle info-icon"></i>
                                <span class="info-text">Autorizas anticipos y pagos finales de viáticos</span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle info-icon"></i>
                                <span class="info-text">Validas facturas, comprobaciones y documentación fiscal</span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle info-icon"></i>
                                <span class="info-text">Generas cotizaciones y reportes financieros detallados</span>
                            </li>
                            <li>
                                <i class="fas fa-exclamation-triangle info-icon"></i>
                                <span class="info-text"><strong>Responsabilidad:</strong> Verificar RFC, montos y legalidad de documentos</span>
                            </li>
                            <li>
                                <i class="fas fa-info-circle info-icon"></i>
                                <span class="info-text">Solo Finanzas autoriza <strong>pagos finales</strong> y cierra comprobaciones</span>
                            </li>
                        </ul>
                        
                        <div class="info-highlight">
                            <div class="info-highlight-title">
                                <i class="fas fa-lightbulb me-2"></i>Consejo Rápido
