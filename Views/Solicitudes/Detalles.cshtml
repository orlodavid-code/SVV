@model SVV.Models.SolicitudesViaje

@{
    ViewData["Title"] = "Detalles de Mi Solicitud";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var fechaVacia = DateOnly.MinValue;
    var duracionViaje = 0;

    if (Model?.FechaSalida != null && Model?.FechaRegreso != null && Model.FechaSalida != fechaVacia && Model.FechaRegreso != fechaVacia)
    {
        var salida = Model.FechaSalida.ToDateTime(TimeOnly.MinValue);
        var regreso = Model.FechaRegreso.ToDateTime(TimeOnly.MinValue);
        duracionViaje = (regreso - salida).Days + 1;
    }

    var estadoCodigo = Model?.Estado?.Codigo ?? "PENDIENTE";
    var totalSolicitado = Model?.RequiereAnticipo == true ? Model.MontoAnticipo ?? 0 : 0;
}

@functions {
    string GetBadgeClass(string estado)
    {
        if (string.IsNullOrEmpty(estado)) return "badge bg-secondary";
        estado = estado.ToUpper();
        if (estado.Contains("PENDIENTE") || estado.Contains("BORRADOR") || estado.Contains("ENVIADA"))
            return "badge bg-warning text-dark";
        if (estado.Contains("APROBADA") || estado.Contains("COMPLETADA"))
            return "badge bg-success";
        if (estado.Contains("RECHAZADA") || estado.Contains("CANCELADA"))
            return "badge bg-danger";
        if (estado.Contains("PAGADO") || estado.Contains("PROCESO"))
            return "badge bg-info";
        return "badge bg-secondary";
    }
}

<div class="container-fluid solicitudes-container">
    <div class="solicitudes-header border-definido">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="solicitudes-title"><i class="fas fa-file-alt me-2"></i>Detalles de Mi Solicitud</h1>
                <p class="solicitudes-subtitle">Revisa el estado y detalles de tu solicitud - @Model?.CodigoSolicitud</p>
            </div>
            <div class="btn-group">
                <a asp-action="Index" class="btn-viamtek-outline">
                    <i class="fas fa-arrow-left me-2"></i>Volver a Mis Solicitudes
                </a>
                <a asp-action="DescargarPdf" asp-route-id="@Model.Id" class="btn-viamtek-gradient" target="_blank">
                    <i class="fas fa-file-pdf me-2"></i>Generar PDF
                </a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="recent-activity-card border-definido">
                <div class="doc-header mb-4 border-bottom-definido">
                    <div class="doc-empresa text-center mb-3">
                        <h2 class="text-accent mb-1">CUVITEK Software S.C.</h2>
                        <p class="text-light opacity-75">SOLICITUD DE VIÁTICOS</p>
                    </div>
                    <div class="row text-center">
                        <div class="col-md-4 mb-2">
                            <strong class="text-accent">Código:</strong>
                            <span class="text-white">@Model?.CodigoSolicitud</span>
                        </div>
                        <div class="col-md-4 mb-2">
                            <strong class="text-accent">Fecha:</strong>
                            <span class="text-white">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="col-md-4 mb-2">
                            <strong class="text-accent">Estado:</strong>
                            <span class="@GetBadgeClass(estadoCodigo) border-definido">@estadoCodigo</span>
                        </div>
                    </div>
                </div>

                <div class="seccion mb-4 border-seccion">
                    <h3 class="seccion-titulo text-accent mb-3 border-bottom-titulo">
                        <i class="fas fa-info-circle me-2"></i>Información General
                    </h3>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-light">Empleado</label>
                            <div class="dato-valor text-white border-dato">@Model?.Empleado?.Nombre @Model?.Empleado?.Apellidos</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-light">Proyecto</label>
                            <div class="dato-valor text-white border-dato">@Model?.NombreProyecto</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-light">Destino</label>
                            <div class="dato-valor text-white border-dato">@Model?.Destino</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-light">Tipo de Viático</label>
                            <div class="dato-valor text-white border-dato">@Model?.TipoViatico?.Nombre</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-light">Duración</label>
                            <div class="dato-valor text-white border-dato">@duracionViaje días</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-light">Monto Anticipo</label>
                            <div class="dato-valor text-success fw-bold border-dato">@(Model?.MontoAnticipo?.ToString("C") ?? "N/A")</div>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label text-light">Periodo</label>
                            <div class="dato-valor text-white border-dato">
                                @(Model?.FechaSalida != DateOnly.MinValue ? Model.FechaSalida.ToString("dd/MM/yyyy") : "-") al
                                @(Model?.FechaRegreso != DateOnly.MinValue ? Model.FechaRegreso.ToString("dd/MM/yyyy") : "-")
                            </div>
                        </div>
                    </div>
                </div>

                <div class="seccion mb-4 border-seccion">
                    <h3 class="seccion-titulo text-accent mb-3 border-bottom-titulo">
                        <i class="fas fa-route me-2"></i>Detalles del Viaje
                    </h3>
                    <div class="mb-3">
                        <label class="form-label text-light">Motivo del Viaje</label>
                        <div class="dato-valor text-white border-dato">@Model?.Motivo</div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model?.DireccionEmpresa))
                    {
                        <div class="mb-3">
                            <label class="form-label text-light">Dirección Destino</label>
                            <div class="dato-valor text-white border-dato">@Model.DireccionEmpresa</div>
                        </div>
                    }
                </div>

                <div class="seccion mb-4 border-seccion">
                    <h3 class="seccion-titulo text-accent mb-3 border-bottom-titulo">
                        <i class="fas fa-bus me-2"></i>Información de Transporte
                    </h3>
                    <div class="row">
                        @if (!string.IsNullOrEmpty(Model?.MedioTrasladoPrincipal))
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light">Medio Traslado Principal</label>
                                <div class="dato-valor text-white border-dato">@Model.MedioTrasladoPrincipal</div>
                            </div>
                        }
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-light">Requiere Taxi Domicilio</label>
                            <div class="dato-valor text-white border-dato">@(Model?.RequiereTaxiDomicilio == true ? "Sí" : "No")</div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model?.DireccionTaxiOrigen))
                        {
                            <div class="col-12 mb-3">
                                <label class="form-label text-light">Dirección Origen Taxi</label>
                                <div class="dato-valor text-white border-dato">@Model.DireccionTaxiOrigen</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model?.DireccionTaxiDestino))
                        {
                            <div class="col-12 mb-3">
                                <label class="form-label text-light">Dirección Destino Taxi</label>
                                <div class="dato-valor text-white border-dato">@Model.DireccionTaxiDestino</div>
                            </div>
                        }
                    </div>
                </div>

                <div class="seccion mb-4 border-seccion">
                    <h3 class="seccion-titulo text-accent mb-3 border-bottom-titulo">
                        <i class="fas fa-hotel me-2"></i>Información de Hospedaje
                    </h3>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-light">Requiere Hospedaje</label>
                            <div class="dato-valor text-white border-dato">@(Model?.RequiereHospedaje == true ? "Sí" : "No")</div>
                        </div>
                        @if (Model?.NochesHospedaje > 0)
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light">Noches Hospedaje</label>
                                <div class="dato-valor text-white border-dato">@Model.NochesHospedaje</div>
                            </div>
                        }
                    </div>
                </div>

                <div class="seccion mb-4 border-seccion">
                    <h3 class="seccion-titulo text-accent mb-3 border-bottom-titulo">
                        <i class="fas fa-list me-2"></i>Información Adicional
                    </h3>
                    <div class="row">
                        @if (!string.IsNullOrEmpty(Model?.EmpresaVisitada))
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light">Empresa Visitada</label>
                                <div class="dato-valor text-white border-dato">@Model.EmpresaVisitada</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model?.LugarComisionDetallado))
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light">Lugar Comisión Detallado</label>
                                <div class="dato-valor text-white border-dato">@Model.LugarComisionDetallado</div>
                            </div>
                        }
                        @if (Model?.NumeroPersonas > 0)
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light">Número de Personas</label>
                                <div class="dato-valor text-white border-dato">@Model.NumeroPersonas</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model?.Colaboradores))
                        {
                            <div class="col-12 mb-3">
                                <label class="form-label text-light">Colaboradores</label>
                                <div class="dato-valor text-white border-dato">@Model.Colaboradores</div>
                            </div>
                        }
                    </div>
                </div>

                @if (Model?.Anticipos != null && Model.Anticipos.Any())
                {
                    <div class="seccion mb-4 border-seccion">
                        <h3 class="seccion-titulo text-accent mb-3 border-bottom-titulo">
                            <i class="fas fa-money-bill-wave me-2"></i>Anticipos Solicitados
                        </h3>
                        
                        <div class="tabla-precios">
                            <div class="table-responsive">
                                <table class="table table-sm table-dark mb-0">
                                    <thead>
                                        <tr>
                                            <th width="60" class="text-center">#</th>
                                            <th>Monto Solicitado</th>
                                            <th width="120" class="text-center">Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var (anticipo, index) in Model.Anticipos.Select((a, i) => (a, i)))
                                        {
                                            <tr class="fila-anticipo">
                                                <td class="text-center align-middle">
                                                    <span class="numero-fila">@(index + 1)</span>
                                                </td>
                                                <td class="align-middle">
                                                    <div class="monto-anticipo text-success fw-bold">
                                                        @anticipo.MontoSolicitado.ToString("C")
                                                    </div>
                                                </td>
                                                <td class="text-center align-middle">
                                                    <span class="badge estado-anticipo @GetBadgeClass(anticipo.Estado) border-definido">
                                                        @anticipo.Estado
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr class="total-concepto">
                                            <td colspan="3" class="text-end">
                                                <strong>Total Anticipos: <span class="subtotal">@Model.Anticipos.Sum(a => a.MontoSolicitado).ToString("C")</span></strong>
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                }

                <div class="seccion mb-4 border-seccion">
                    <h3 class="seccion-titulo text-accent mb-3 border-bottom-titulo">
                        <i class="fas fa-clipboard-list me-2"></i>Instrucciones y Observaciones
                    </h3>
                    <div class="alert alert-info border-definido">
                        <p class="mb-2"><strong>Plazo para comprobación:</strong> 5 días hábiles posteriores al término de la comisión.</p>
                        <p class="mb-2"><strong>Documentación requerida:</strong> Facturas, tickets, comprobantes en formato PDF o XLS.</p>
                        <p class="mb-0">
                            <strong>Periodo del viaje:</strong> @duracionViaje día(s) del
                            @(Model?.FechaSalida != DateOnly.MinValue ? Model.FechaSalida.ToString("dd/MM/yyyy") : "-") al
                            @(Model?.FechaRegreso != DateOnly.MinValue ? Model.FechaRegreso.ToString("dd/MM/yyyy") : "-").
                        </p>
                    </div>
                </div>

                <div class="seccion border-seccion">
                    <h3 class="seccion-titulo text-accent mb-3 border-bottom-titulo">
                        <i class="fas fa-signature me-2"></i>Autorizaciones
                    </h3>
                    <div class="row text-center">
                        <div class="col-md-4 mb-3">
                            <div class="firma-item p-3 border-firma">
                                <div class="firma-label text-light mb-2">Solicitante</div>
                                <div class="firma-linea border-bottom mb-2" style="height: 2px;"></div>
                                <div class="firma-nombre text-muted">Nombre y Firma</div>
                                <div class="firma-cargo text-accent">SOLICITANTE</div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="firma-item p-3 border-firma">
                                <div class="firma-label text-light mb-2">Jefe Inmediato</div>
                                <div class="firma-linea border-bottom mb-2" style="height: 2px;"></div>
                                <div class="firma-nombre text-muted">Nombre y Firma</div>
                                <div class="firma-cargo text-accent">JEFE INMEDIATO</div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="firma-item p-3 border-firma">
                                <div class="firma-label text-light mb-2">Finanzas</div>
                                <div class="firma-linea border-bottom mb-2" style="height: 2px;"></div>
                                <div class="firma-nombre text-muted">Nombre y Firma</div>
                                <div class="firma-cargo text-accent">FINANZAS</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="doc-footer mt-4 pt-3 border-top-definido">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">
                                Documento generado el @DateTime.Now.ToString("dd/MM/yyyy a las HH:mm")
                            </small>
                        </div>
                        <div class="col-md-6 text-end">
                            <small class="text-muted">Página 1 de 1</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row detalles-botones">
        <div class="col-12 text-center">
            @if (Model?.EstadoId == 1) // BORRADOR
            {
                <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-editar-solicitud me-3">
                    <i class="fas fa-edit me-2"></i>Editar Solicitud
                </a>
                
                <form asp-action="EnviarAprobacion" asp-route-id="@Model.Id" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-enviar-aprobacion me-3">
                        <i class="fas fa-paper-plane me-2"></i>Enviar a Aprobación
                    </button>
                </form>
                
                <form asp-action="Eliminar" asp-route-id="@Model.Id" method="post" style="display: inline;" id="formEliminar">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-eliminar-solicitud" onclick="return confirmDelete()">
                        <i class="fas fa-trash me-2"></i>Eliminar
                    </button>
                </form>
            }
            else
            {
                <a asp-action="Index" class="btn btn-volver-solicitud me-3">
                    <i class="fas fa-arrow-left me-2"></i>Volver a Mis Solicitudes
                </a>
                
                @if (Model?.EstadoId == 9) // APROBADA_DIRECCION
                {
                    <a asp-controller="Comprobaciones" asp-action="Comprobar" asp-route-solicitudId="@Model.Id" 
                       class="btn btn-comprobar-gastos">
                        <i class="fas fa-receipt me-2"></i>Comprobar Gastos
                    </a>
                }
            }
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/solicitudes.css" asp-append-version="true" />
    <style>
        /* ===== ESTILOS GENERALES DE LA VISTA ===== */
        .border-definido {
            border: 2px solid var(--border-light) !important;
            border-radius: var(--border-radius-md) !important;
        }

        .border-seccion {
            border: 1.5px solid rgba(92, 200, 123, 0.2) !important;
            border-radius: var(--border-radius-md) !important;
            padding: 1.5rem !important;
            background: rgba(25, 35, 45, 0.7) !important;
            backdrop-filter: blur(10px) !important;
        }

        .border-bottom-titulo {
            border-bottom: 2px solid var(--viamtek-green) !important;
            padding-bottom: 0.75rem !important;
        }

        .border-bottom-definido {
            border-bottom: 3px solid var(--border-light) !important;
            padding-bottom: 1.5rem !important;
        }

        .border-top-definido {
            border-top: 2px solid var(--border-light) !important;
        }

        .border-dato {
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            border-radius: var(--border-radius-sm) !important;
            padding: 0.75rem 1rem !important;
            background: rgba(255, 255, 255, 0.05) !important;
            min-height: 48px !important;
            display: flex !important;
            align-items: center !important;
        }

        .border-firma {
            border: 2px solid var(--border-light) !important;
            border-radius: var(--border-radius-md) !important;
            background: rgba(30, 40, 50, 0.8) !important;
            transition: all var(--transition-normal) !important;
        }

        .border-firma:hover {
            border-color: var(--viamtek-green) !important;
            transform: translateY(-2px) !important;
            box-shadow: 0 4px 15px rgba(92, 200, 123, 0.2) !important;
        }

        .badge.border-definido {
            border: 1px solid rgba(255, 255, 255, 0.3) !important;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4) !important;
        }

        .seccion {
            transition: all var(--transition-normal) !important;
        }

        .seccion:hover {
            border-color: rgba(92, 200, 123, 0.4) !important;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3) !important;
        }

        .dato-valor {
            font-weight: 500 !important;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5) !important;
        }

        /* Tabla de anticipos */
        .tabla-precios {
            background: rgba(255, 255, 255, 0.02) !important;
            border-radius: 8px !important;
            padding: 1rem !important;
            margin-top: 0 !important;
        }

        .tabla-precios .table {
            width: 100% !important;
            border-collapse: separate !important;
            border-spacing: 0 !important;
            margin-bottom: 0 !important;
        }

        .tabla-precios .table-dark thead th {
            border: none !important;
            color: var(--text-secondary) !important;
            font-weight: 600 !important;
            font-size: 0.8rem !important;
            padding: 10px 8px !important;
            text-transform: uppercase !important;
            letter-spacing: 0.5px !important;
            background: rgba(255, 255, 255, 0.05) !important;
            white-space: nowrap !important;
        }

        .tabla-precios .table-dark tbody td {
            border: none !important;
            padding: 12px 8px !important;
            vertical-align: middle !important;
            background: transparent !important;
        }

        .tabla-precios .fila-anticipo {
            transition: background-color 0.2s ease;
            background: rgba(35, 45, 55, 0.6) !important;
        }

        .tabla-precios .fila-anticipo:hover {
            background-color: rgba(92, 200, 123, 0.05) !important;
        }

        .tabla-precios .fila-anticipo td:first-child {
            width: 60px !important;
            text-align: center !important;
            padding: 12px 4px !important;
        }

        .tabla-precios .numero-fila {
            color: var(--text-secondary);
            font-weight: 700;
            font-size: 0.9rem;
            display: inline-block;
        }

        .tabla-precios .monto-anticipo {
            font-size: 1rem !important;
            font-weight: 700 !important;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3) !important;
        }

        .tabla-precios .fila-anticipo td:last-child {
            width: 120px !important;
            text-align: center !important;
            padding: 12px 4px !important;
        }

        .tabla-precios .estado-anticipo {
            font-size: 0.75rem !important;
            padding: 0.4rem 0.6rem !important;
            border-radius: 20px !important;
            text-transform: uppercase !important;
            letter-spacing: 0.5px !important;
        }

        .tabla-precios .total-concepto {
            border-top: 2px solid var(--viamtek-green) !important;
            background: rgba(92, 200, 123, 0.1) !important;
        }

        .tabla-precios .total-concepto td {
            padding: 1rem 0.5rem !important;
            font-size: 1rem !important;
        }

        .tabla-precios .subtotal {
            color: var(--viamtek-green) !important;
            font-weight: 700 !important;
            font-size: 1.1rem !important;
            margin-left: 5px !important;
        }

        /* Botones de acción */
        .btn-editar-solicitud,
        .btn-enviar-aprobacion,
        .btn-eliminar-solicitud,
        .btn-volver-solicitud,
        .btn-comprobar-gastos {
            border: 2px solid transparent !important;
            border-radius: var(--border-radius-sm) !important;
            padding: 0.875rem 1.75rem !important;
            font-weight: 700 !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            transition: all var(--transition-normal) !important;
            font-size: 0.95rem !important;
            min-height: 52px !important;
            position: relative !important;
            overflow: hidden !important;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3) !important;
            margin: 0 5px !important;
        }

        .btn-editar-solicitud::before,
        .btn-enviar-aprobacion::before,
        .btn-eliminar-solicitud::before,
        .btn-volver-solicitud::before,
        .btn-comprobar-gastos::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transition: left 0.6s;
        }

        .btn-editar-solicitud:hover::before,
        .btn-enviar-aprobacion:hover::before,
        .btn-eliminar-solicitud:hover::before,
        .btn-volver-solicitud:hover::before,
        .btn-comprobar-gastos:hover::before {
            left: 100%;
        }

