@section Scripts {
    <!-- jQuery (ya está en _Layout, pero por si acaso) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- jQuery Validation -->
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <!-- Select2 -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        // ============================================
        // VARIABLES GLOBALES
        // ============================================
        let estadosData = [];
        const LIMITE_PERSONAS = 30;

        // Elementos del DOM
        const estadoSelect = document.getElementById('estadoSelect');
        const municipioSelect = document.getElementById('municipioSelect');
        const destinoHidden = document.getElementById('DestinoHidden');
        const destinoPreview = document.getElementById('destinoPreview');
        const requiereHospedaje = document.getElementById('RequiereHospedaje');
        const nochesHospedajeGroup = document.getElementById('nochesHospedajeGroup');
        const requiereTaxi = document.getElementById('RequiereTaxiDomicilio');
        const direccionTaxiGroup = document.getElementById('direccionTaxiGroup');
        const numeroPersonasInput = document.getElementById('NumeroPersonasInput');
        const cuerpoTablaPersonas = document.getElementById('personas-body');
        const totalPersonasSpan = document.getElementById('total-personas');
        const form = document.getElementById('formSolicitud');
        const btnEditar = document.getElementById('btnEditarSolicitud');

        // Destino existente desde el modelo
        const destinoExistente = '@Model.Destino';
        let estadoExistente = '', municipioExistente = '';
        if (destinoExistente) {
            const partes = destinoExistente.split(', ');
            if (partes.length === 2) {
                municipioExistente = partes[0];
                estadoExistente = partes[1];
            } else {
                estadoExistente = destinoExistente;
            }
        }

        // ============================================
        // INICIALIZACIÓN CON JQUERY (para Select2)
        // ============================================
        $(async function () {
            console.log('Inicializando formulario de edición...');

            // 1. Inicializar Select2
            $('#estadoSelect').select2({
                theme: 'bootstrap-5',
                placeholder: 'Escribe para buscar estado...',
                allowClear: true,
                width: '100%'
            });

            $('#municipioSelect').select2({
                theme: 'bootstrap-5',
                placeholder: 'Primero selecciona un estado',
                allowClear: true,
                width: '100%'
            });

            // 2. Cargar estados
            await cargarEstados();

            // 3. Configurar campos condicionales (hospedaje, taxi)
            configurarCamposCondicionales();

            // 4. Configurar validación de fechas y números
            configurarValidacionFechas();
            configurarValidacionNumeros();

            // 5. Inicializar validación jQuery
            inicializarValidacion();

            // 6. Inicializar tabla de personas
            if (numeroPersonasInput) {
                actualizarTablaPersonas();
            }

            console.log('Formulario de edición inicializado correctamente');
        });

        // ============================================
        // FUNCIONES DE ESTADOS/MUNICIPIOS
        // ============================================
        async function cargarEstados() {
            try {
                const response = await fetch('/data/estados-mexico.json');
                if (!response.ok) throw new Error('No se pudo cargar el JSON');
                const data = await response.json();
                estadosData = data.estados || [];

                // Llenar select de estados
                $('#estadoSelect').empty().append('<option value=""></option>');
                estadosData.forEach(estado => {
                    $('#estadoSelect').append(new Option(estado.nombre, estado.nombre));
                });

                // Si hay estado existente, seleccionarlo y disparar cambio
                if (estadoExistente) {
                    $('#estadoSelect').val(estadoExistente).trigger('change');
                }

                console.log(`Estados cargados: ${estadosData.length}`);
            } catch (error) {
                console.error('Error cargando estados:', error);
            }
        }

        $('#estadoSelect').on('change', function () {
            const estadoNombre = $(this).val();
            const $municipio = $('#municipioSelect');
            $municipio.empty().append('<option value=""></option>').prop('disabled', true);

            if (!estadoNombre) {
                actualizarDestino();
                return;
            }

            const estado = estadosData.find(e => e.nombre === estadoNombre);
            if (!estado) {
                console.warn('Estado no encontrado');
                return;
            }

            // Ordenar municipios
            const municipiosOrdenados = estado.municipios.slice().sort((a, b) => a.localeCompare(b, 'es'));
            municipiosOrdenados.forEach(m => {
                $municipio.append(new Option(m, m));
            });

            $municipio.prop('disabled', false).trigger('change.select2');

            // Si hay municipio existente, seleccionarlo después de poblar
            if (municipioExistente) {
                $municipio.val(municipioExistente).trigger('change');
                municipioExistente = ''; // para que no se vuelva a seleccionar en futuros cambios
            }

            actualizarDestino();
        });

        $('#municipioSelect').on('change', actualizarDestino);

        function actualizarDestino() {
            const estado = $('#estadoSelect').val();
            const municipio = $('#municipioSelect').val();
            if (estado && municipio) {
                const destino = `${municipio}, ${estado}`;
                destinoHidden.value = destino;
                destinoPreview.textContent = destino;
                destinoPreview.style.color = '#28a745';
            } else if (estado) {
                destinoHidden.value = estado;
                destinoPreview.textContent = estado;
                destinoPreview.style.color = '#ffc107';
            } else {
                destinoHidden.value = '';
                destinoPreview.textContent = 'No seleccionado';
                destinoPreview.style.color = '#dc3545';
            }
        }

        // ============================================
        // CAMPOS CONDICIONALES
        // ============================================
        function configurarCamposCondicionales() {
            if (requiereHospedaje && nochesHospedajeGroup) {
                requiereHospedaje.addEventListener('change', function () {
                    nochesHospedajeGroup.style.display = this.checked ? 'block' : 'none';
                    if (!this.checked) document.querySelector('[name="NochesHospedaje"]').value = '';
                });
                nochesHospedajeGroup.style.display = requiereHospedaje.checked ? 'block' : 'none';
            }

            if (requiereTaxi && direccionTaxiGroup) {
                requiereTaxi.addEventListener('change', function () {
                    direccionTaxiGroup.style.display = this.checked ? 'block' : 'none';
                    if (!this.checked) {
                        document.querySelector('[name="DireccionTaxiOrigen"]').value = '';
                        document.querySelector('[name="DireccionTaxiDestino"]').value = '';
                    }
                });
                direccionTaxiGroup.style.display = requiereTaxi.checked ? 'block' : 'none';
            }
        }

        // ============================================
        // TABLA DE PERSONAS
        // ============================================
        function actualizarTablaPersonas() {
            let numeroPersonas = parseInt(numeroPersonasInput.value) || 1;
            if (numeroPersonas < 1) numeroPersonas = 1;
            if (numeroPersonas > LIMITE_PERSONAS) {
                mostrarErrorPersonas(`No se permiten más de ${LIMITE_PERSONAS} personas.`);
                numeroPersonas = LIMITE_PERSONAS;
                numeroPersonasInput.value = LIMITE_PERSONAS;
            } else {
                limpiarErrorPersonas();
            }

            const filasActuales = cuerpoTablaPersonas.querySelectorAll('.fila-persona').length;

            if (numeroPersonas > filasActuales) {
                for (let i = filasActuales; i < numeroPersonas; i++) {
                    agregarFilaPersona(i);
                }
            } else if (numeroPersonas < filasActuales) {
                for (let i = filasActuales - 1; i >= numeroPersonas; i--) {
                    if (i > 0) eliminarFilaPersona(i);
                }
            }

            reindexarFilas();
            actualizarContadorPersonas();
        }

        function agregarFilaPersona(index) {
            const fila = document.createElement('tr');
            fila.className = 'fila-persona align-middle';
            const esSolicitante = index === 0;
            fila.innerHTML = `
                <td class="text-center"><span class="badge ${esSolicitante ? 'bg-primary' : 'bg-secondary'} numero-fila">${index+1}</span></td>
                <td>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                        <input type="text" class="form-control nombre-input" name="NombresPersonas[${index}]" placeholder="${esSolicitante ? 'Tu nombre completo' : 'Nombre del colaborador'}" maxlength="100" />
                    </div>
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-outline-danger btn-eliminar-persona" ${esSolicitante ? 'disabled' : ''}><i class="fas fa-times"></i></button>
                </td>
            `;
            cuerpoTablaPersonas.appendChild(fila);
        }

        function eliminarFilaPersona(index) {
            const filas = cuerpoTablaPersonas.querySelectorAll('.fila-persona');
            if (filas[index] && index > 0) filas[index].remove();
        }

        function reindexarFilas() {
            const filas = cuerpoTablaPersonas.querySelectorAll('.fila-persona');
            filas.forEach((fila, index) => {
                fila.querySelector('.numero-fila').textContent = index + 1;
                const input = fila.querySelector('.nombre-input');
                input.name = `NombresPersonas[${index}]`;
                input.placeholder = index === 0 ? 'Tu nombre completo' : 'Nombre del colaborador';
                const badge = fila.querySelector('.numero-fila');
                badge.className = `badge ${index === 0 ? 'bg-primary' : 'bg-secondary'} numero-fila`;
                const btn = fila.querySelector('.btn-eliminar-persona');
                if (btn) btn.disabled = index === 0;
            });
            numeroPersonasInput.value = filas.length;
        }

        function actualizarContadorPersonas() {
            const total = cuerpoTablaPersonas.querySelectorAll('.fila-persona').length;
            if (totalPersonasSpan) totalPersonasSpan.textContent = total;
        }

        function mostrarErrorPersonas(mensaje) {
            let errorSpan = document.getElementById('error-personas');
            if (!errorSpan) {
                errorSpan = document.createElement('div');
                errorSpan.id = 'error-personas';
                errorSpan.className = 'text-danger mt-1';
                numeroPersonasInput.parentNode.appendChild(errorSpan);
            }
            errorSpan.textContent = mensaje;
        }

        function limpiarErrorPersonas() {
            const errorSpan = document.getElementById('error-personas');
            if (errorSpan) errorSpan.textContent = '';
        }

        numeroPersonasInput?.addEventListener('input', actualizarTablaPersonas);

        document.addEventListener('click', function (e) {
            const btn = e.target.closest('.btn-eliminar-persona');
            if (!btn || btn.disabled) return;
            const fila = btn.closest('tr');
            if (fila) {
                const index = Array.from(fila.parentNode.children).indexOf(fila);
                eliminarFilaPersona(index);
                reindexarFilas();
                actualizarContadorPersonas();
            }
        });

        window.agregarFilaPersonaManual = function () {
            const nuevaCantidad = parseInt(numeroPersonasInput.value) + 1;
            if (nuevaCantidad <= LIMITE_PERSONAS) {
                numeroPersonasInput.value = nuevaCantidad;
                actualizarTablaPersonas();
            }
        };

        // ============================================
        // VALIDACIÓN DE FECHAS
        // ============================================
        if ($.validator) {
            $.extend($.validator.messages, {
                required: "Este campo es obligatorio.",
                date: "Por favor, introduce una fecha válida (AAAA-MM-DD).",
                number: "Por favor, introduce un número válido."
            });
        }

        $.validator.addMethod("fechaRealista", function (value, element) {
            if (!value) return true;
            const regex = /^\d{4}-\d{2}-\d{2}$/;
            if (!regex.test(value)) return false;
            const fecha = new Date(value);
            if (isNaN(fecha.getTime())) return false;
            const hoy = new Date();
            hoy.setHours(0, 0, 0, 0);
            const maxFecha = new Date();
            maxFecha.setFullYear(hoy.getFullYear() + 5);
            return fecha >= hoy && fecha <= maxFecha;
        }, "La fecha debe ser a partir de hoy y no mayor a 5 años en el futuro.");

        $.validator.addMethod("entero", function (value, element) {
            if (!value) return true;
            return /^\d+$/.test(value) && !value.includes('.');
        }, "Por favor, introduce un número entero.");

        function configurarValidacionFechas() {
            const fechaSalida = $('#FechaSalida');
            const fechaRegreso = $('#FechaRegreso');
            const hoy = new Date().toISOString().split('T')[0];

            if (fechaSalida.length) {
                fechaSalida.attr('min', hoy);
                fechaSalida.on('change', function () {
                    if (fechaRegreso.val() && fechaRegreso.val() < this.value) {
                        fechaRegreso.val(this.value);
                    }
                    fechaRegreso.attr('min', this.value);
                });
            }
            if (fechaRegreso.length) {
                fechaRegreso.attr('min', hoy);
            }
        }

        // ============================================
        // VALIDACIÓN NUMÉRICA
        // ============================================
        function configurarValidacionNumeros() {
            const inputNoches = document.querySelector('[name="NochesHospedaje"]');
            function soloNumeros(e) {
                if (!/[0-9]|Backspace|Delete|ArrowLeft|ArrowRight|Tab/.test(e.key)) e.preventDefault();
            }
            if (numeroPersonasInput) {
                numeroPersonasInput.addEventListener('keydown', soloNumeros);
            }
            if (inputNoches) {
                inputNoches.addEventListener('keydown', soloNumeros);
                inputNoches.addEventListener('input', function () {
                    if (!requiereHospedaje.checked) {
                        this.value = '';
                    } else {
                        let valor = parseInt(this.value) || 1;
                        if (valor < 1) valor = 1;
                        if (valor > 30) valor = 30;
                        this.value = valor;
                    }
                });
            }
        }

        // ============================================
        // CONFIGURAR JQUERY VALIDATION
        // ============================================
        function inicializarValidacion() {
            if (!$.validator) return;

            $('#formSolicitud').validate({
                rules: {
                    NombreProyecto: { required: true },
                    TipoViaticoId: { required: true },
                    FechaSalida: { required: true, date: true, fechaRealista: true },
                    FechaRegreso: { required: true, date: true, fechaRealista: true },
                    EmpresaVisitada: { required: true },
                    LugarComisionDetallado: { required: true },
                    Motivo: { required: true },
                    NochesHospedaje: {
                        required: function () { return requiereHospedaje && requiereHospedaje.checked; },
                        entero: true,
                        range: [1, 30]
                    },
                    NumeroPersonas: {
                        required: true,
                        entero: true,
                        range: [1, LIMITE_PERSONAS]
                    },
                    DireccionTaxiOrigen: {
                        required: function () { return requiereTaxi && requiereTaxi.checked; }
                    },
                    DireccionTaxiDestino: {
                        required: function () { return requiereTaxi && requiereTaxi.checked; }
                    }
                },
                messages: {
                    FechaSalida: {
                        fechaRealista: "La fecha debe ser a partir de hoy y no mayor a 5 años."
                    },
                    FechaRegreso: {
                        fechaRealista: "La fecha debe ser a partir de hoy y no mayor a 5 años."
                    },
                    NochesHospedaje: { range: "Las noches deben estar entre 1 y 30" },
                    NumeroPersonas: { range: `El número de personas debe estar entre 1 y ${LIMITE_PERSONAS}` }
                },
                errorElement: 'span',
                errorPlacement: function (error, element) {
                    error.addClass('invalid-feedback');
                    element.closest('.mb-3').append(error);
                },
                highlight: function (element) {
                    $(element).addClass('is-invalid').removeClass('is-valid');
                },
                unhighlight: function (element) {
                    $(element).removeClass('is-invalid').addClass('is-valid');
                },
                submitHandler: function (formEl) {
                    // Validaciones adicionales antes de enviar
                    const estado = $('#estadoSelect').val();
                    const municipio = $('#municipioSelect').val();

                    if (!estado) {
                        Swal.fire({ icon: 'error', title: 'Error', text: 'Debes seleccionar un estado' });
                        $('#estadoSelect').focus();
                        return false;
                    }
                    if (!municipio) {
                        Swal.fire({ icon: 'error', title: 'Error', text: 'Debes seleccionar un municipio' });
                        $('#municipioSelect').focus();
                        return false;
                    }
                    const nombresValidos = validarNombresPersonas();
                    if (!nombresValidos) {
                        Swal.fire({ icon: 'error', title: 'Error', text: 'Debes completar todos los nombres de las personas' });
                        return false;
                    }
                    const fechaSalida = new Date($('#FechaSalida').val());
                    const fechaRegreso = new Date($('#FechaRegreso').val());
                    if (fechaRegreso < fechaSalida) {
                        Swal.fire({ icon: 'error', title: 'Error', text: 'La fecha de regreso debe ser posterior a la fecha de salida' });
                        return false;
                    }

                    // Deshabilitar botón y enviar
                    $('#btnEditarSolicitud').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Guardando...');
                    formEl.submit();
                }
            });
        }

        // ============================================
        // FUNCIONES AUXILIARES
        // ============================================
        function validarNombresPersonas() {
            const inputs = document.querySelectorAll('.nombre-input');
            let ok = true;
            inputs.forEach(i => {
                if (!i.value.trim()) {
                    i.classList.add('is-invalid');
                    ok = false;
                } else {
                    i.classList.remove('is-invalid');
                }
            });
            return ok;
        }

        // ============================================
        // ENVÍO A APROBACIÓN
        // ============================================
        window.enviarAprobacion = function (solicitudId) {
            if (!validarDestino() || !validarNombresPersonas() || !validarFechas()) return;

            Swal.fire({
                title: '¿Enviar a aprobación?',
                html: '<p><strong>Una vez enviada no podrás editarla.</strong></p><p>Se enviará a tu jefe directo (si tienes) o directamente a Finanzas.</p>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, enviar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    const btn = document.getElementById('btnEnviarAprobacion');
                    btn.disabled = true;
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Enviando...';
                    document.getElementById('formEnviarAprobacion').submit();
                }
            });
        };

        function validarDestino() {
            if (!estadoSelect.value) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Debes seleccionar un estado.' });
                estadoSelect.focus();
                return false;
            }
            if (!municipioSelect.value) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Debes seleccionar un municipio.' });
                municipioSelect.focus();
                return false;
            }
            return true;
        }

        function validarFechas() {
            const salida = new Date(document.getElementById('FechaSalida').value);
            const regreso = new Date(document.getElementById('FechaRegreso').value);
            if (regreso < salida) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'La fecha de regreso debe ser posterior a la salida.' });
                return false;
            }
            return true;
        }
    </script>
}