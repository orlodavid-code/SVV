@model SVV.ViewModels.CrearSolicitudViewModel

@{
    ViewData["Title"] = "Editar Solicitud de Viáticos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4 form-solicitud-container">
    <div class="solicitud-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="solicitud-title"><i class="fas fa-edit me-2"></i>Editar Solicitud de Viáticos</h1>
                <p class="solicitud-subtitle">Modifica los datos de la solicitud existente</p>
            </div>
            <a asp-action="Index" class="btn btn-solicitud-outline">
                <i class="fas fa-arrow-left me-1"></i> Volver
            </a>
        </div>
    </div>

    <div class="solicitud-card">
        <div class="solicitud-card-body">
            @using (Html.BeginForm("Editar", "Solicitudes", FormMethod.Post, new { id = "formSolicitud", autocomplete = "off" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.Id)

                <!-- ========== INFORMACIÓN BÁSICA ========== -->
                <div class="mb-4">
                    <h5 class="mb-3"><i class="fas fa-info-circle me-2"></i>Información Básica</h5>
                    <div class="row gx-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NombreProyecto" class="form-label">Nombre del Proyecto *</label>
                            <input asp-for="NombreProyecto" class="form-control" placeholder="Ej: Proyecto de Infraestructura 2024" required />
                            <span asp-validation-for="NombreProyecto" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="TipoViaticoId" class="form-label">Tipo de Viático *</label>
                            <select asp-for="TipoViaticoId" id="estiloSelect" asp-items="@(new SelectList(Model.TiposViatico, "Id", "Nombre"))" class="form-select" required>
                                <option value="">-- Seleccione un tipo --</option>
                            </select>
                            <span asp-validation-for="TipoViaticoId" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <hr />

                <!-- ========== ANTICIPO ========== -->
                <div class="mb-4">
                    <h5 class="mb-3"><i class="fas fa-money-bill-wave me-2"></i>Anticipo</h5>
                    <div class="row gx-3">
                        <div class="col-12 mb-4">
                            <div class="form-check form-switch mb-3">
                                <input asp-for="requiere_anticipo" class="form-check-input" id="RequiereAnticipo" type="checkbox" />
                                <label asp-for="requiere_anticipo" class="form-check-label fw-bold">¿Requiere anticipo?</label>
                            </div>
                            <div class="alert alert-info mt-2">
                                <i class="fas fa-info-circle me-2"></i> Si selecciona "Sí", el departamento de Finanzas determinará el monto del anticipo.
                            </div>
                        </div>
                    </div>
                </div>
                <hr />

                <!-- ========== DESTINO Y FECHAS ========== -->
                <div class="mb-4">
                    <h5 class="mb-3"><i class="fas fa-map-marked-alt me-2"></i>Destino y Fechas</h5>
                    <div class="row gx-3">
                        <!-- Estado con Select2 -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Estado *</label>
                            <select id="estadoSelect" class="form-select" data-placeholder="Escribe para buscar estado...">
                                <option value=""></option>
                            </select>
                            <div class="invalid-feedback">Por favor selecciona un estado</div>
                        </div>
                        <!-- Municipio con Select2 -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Municipio *</label>
                            <select id="municipioSelect" class="form-select" disabled data-placeholder="Primero selecciona un estado...">
                                <option value=""></option>
                            </select>
                            <div class="invalid-feedback">Por favor selecciona un municipio</div>
                        </div>

                        <!-- Campo Destino oculto -->
                        <input type="hidden" asp-for="Destino" id="DestinoHidden" />

                        <!-- Vista previa del destino -->
                        <div class="col-12 mb-3">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                Destino seleccionado: <strong id="destinoPreview">No seleccionado</strong>
                            </div>
                        </div>

                        <!-- Dirección específica -->
                        <div class="col-12 mb-3">
                            <label asp-for="DireccionEmpresa" class="form-label">Dirección específica del destino</label>
                            <input asp-for="DireccionEmpresa" class="form-control" placeholder="Calle, número, colonia, referencia..." />
                            <span asp-validation-for="DireccionEmpresa" class="text-danger"></span>
                            <small class="form-text text-muted">Dirección exacta de la empresa o lugar a visitar</small>
                        </div>

                        <!-- Fechas -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaSalida" class="form-label">Fecha de Salida *</label>
                            <input asp-for="FechaSalida" id="FechaSalida" type="date" class="form-control" required />
                            <span asp-validation-for="FechaSalida" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaRegreso" class="form-label">Fecha de Regreso *</label>
                            <input asp-for="FechaRegreso" id="FechaRegreso" type="date" class="form-control" required />
                            <span asp-validation-for="FechaRegreso" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="HoraSalida" class="form-label">Hora de Salida</label>
                            <input asp-for="HoraSalida" type="time" class="form-control" />
                            <span asp-validation-for="HoraSalida" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="HoraRegreso" class="form-label">Hora de Regreso</label>
                            <input asp-for="HoraRegreso" type="time" class="form-control" />
                            <span asp-validation-for="HoraRegreso" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <hr />

                <!-- ========== TRANSPORTE ========== -->
                <div class="mb-4">
                    <h5 class="mb-3"><i class="fas fa-car me-2"></i>Transporte</h5>
                    <div class="row gx-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="MedioTrasladoPrincipal" class="form-label">Medio de traslado</label>
                            <select id="MedioTraslado" asp-for="MedioTrasladoPrincipal" class="form-select">
                                <option value="">-- Seleccione --</option>
                                <option>Vehículo Utilitario</option>
                                <option>Vehículo Personal</option>
                                <option>Transporte Público</option>
                                <option>Taxi</option>
                                <option>Uber/Didi</option>
                                <option>Avión</option>
                                <option>Autobús</option>
                            </select>
                            <span asp-validation-for="MedioTrasladoPrincipal" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-center">
                            <div class="form-check form-switch w-100">
                                <input asp-for="RequiereTaxiDomicilio" class="form-check-input" id="RequiereTaxiDomicilio" type="checkbox" />
                                <label asp-for="RequiereTaxiDomicilio" class="form-check-label ms-2">¿Requiere taxi desde domicilio?</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 mb-3" id="direccionTaxiGroup" style="@(Model.RequiereTaxiDomicilio ? "" : "display:none;")">
                        <div class="row gx-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DireccionTaxiOrigen" class="form-label">Dirección de origen (domicilio)</label>
                                <input asp-for="DireccionTaxiOrigen" class="form-control" placeholder="Calle, número, colonia de donde partirá el taxi..." />
                                <span asp-validation-for="DireccionTaxiOrigen" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DireccionTaxiDestino" class="form-label">Dirección de destino</label>
                                <input asp-for="DireccionTaxiDestino" class="form-control" placeholder="Calle, número, colonia a donde irá el taxi..." />
                                <span asp-validation-for="DireccionTaxiDestino" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
                <hr />

                <!-- ========== EMPRESA Y ACTIVIDADES ========== -->
                <div class="mb-4">
                    <h5 class="mb-3"><i class="fas fa-building me-2"></i>Empresa y Actividades</h5>
                    <div class="mb-3">
                        <label asp-for="EmpresaVisitada" class="form-label">Empresa visitada *</label>
                        <input asp-for="EmpresaVisitada" class="form-control" required />
                        <span asp-validation-for="EmpresaVisitada" class="text-danger"></span>
                        <small class="form-text text-muted">Nombre de la empresa o cliente a visitar</small>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LugarComisionDetallado" class="form-label">Lugar de comisión detallado *</label>
                        <textarea asp-for="LugarComisionDetallado" class="form-control" rows="3" required></textarea>
                        <span asp-validation-for="LugarComisionDetallado" class="text-danger"></span>
                        <small class="form-text text-muted">Dirección específica, oficina, departamento, etc.</small>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Motivo" class="form-label">Motivo del viaje *</label>
                        <textarea asp-for="Motivo" class="form-control" rows="4" required></textarea>
                        <span asp-validation-for="Motivo" class="text-danger"></span>
                        <small class="form-text text-muted">Describe las actividades, objetivos y resultados esperados del viaje</small>
                    </div>
                </div>
                <hr />

                <!-- ========== INFORMACIÓN DE PERSONAS ========== -->
                <div class="mb-4">
                    <h5 class="mb-3"><i class="fas fa-users me-2"></i>Información de Personas</h5>
                    <div class="row gx-3">
                        <div class="col-md-6 mb-3 d-flex align-items-center">
                            <div class="form-check form-switch w-100">
                                <input asp-for="RequiereHospedaje" class="form-check-input" id="RequiereHospedaje" type="checkbox" />
                                <label asp-for="RequiereHospedaje" class="form-check-label ms-2">¿Requiere hospedaje?</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3" id="nochesHospedajeGroup" style="@(Model.RequiereHospedaje ? "" : "display:none;")">
                            <label asp-for="NochesHospedaje" class="form-label">Noches de Hospedaje</label>
                            <input asp-for="NochesHospedaje" type="number" class="form-control" min="1" />
                            <span asp-validation-for="NochesHospedaje" class="text-danger"></span>
                        </div>

                        <div class="col-12 mb-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-dark text-white">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-users me-2"></i>
                                            <h6 class="mb-0">Personas que Viajarán</h6>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <label class="mb-0 text-light">Número:</label>
                                            <input asp-for="NumeroPersonas" class="form-control form-control-sm" style="width:80px;" type="number" min="1" max="50" id="NumeroPersonasInput" />
                                            <button type="button" class="btn btn-sm btn-success" onclick="agregarFilaPersonaManual()">
                                                <i class="fas fa-plus me-1"></i>Agregar
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="alert alert-info mb-3">
                                        <i class="fas fa-info-circle me-2"></i> Ingresa los nombres completos de todas las personas que viajarán. <strong>El primer nombre debe ser el tuyo.</strong>
                                    </div>
                                    <div class="table-responsive">
                                        <table class="table table-hover mb-0">
                                            <thead class="table-dark">
                                                <tr>
                                                    <th width="60" class="text-center">#</th>
                                                    <th>Nombre Completo *</th>
                                                    <th width="80" class="text-center">Acciones</th>
                                                </tr>
                                            </thead>
                                            <tbody id="personas-body">
                                                @if (Model.NombresPersonas != null && Model.NombresPersonas.Any())
                                                {
                                                    for (int i = 0; i < Model.NombresPersonas.Count; i++)
                                                    {
                                                        <tr class="fila-persona align-middle">
                                                            <td class="text-center"><span class="badge bg-secondary numero-fila">@(i+1)</span></td>
                                                            <td>
                                                                <div class="input-group input-group-sm">
                                                                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                                                                    <input type="text" class="form-control nombre-input" name="NombresPersonas[@i]" value="@Model.NombresPersonas[i]" placeholder="@(i==0?"Tu nombre completo":$"Nombre del colaborador {i+1}")" required maxlength="100" />
                                                                </div>
                                                            </td>
                                                            <td class="text-center">
                                                                @if (i > 0)
                                                                {
                                                                    <button type="button" class="btn btn-sm btn-outline-danger btn-eliminar-persona"><i class="fas fa-times"></i></button>
                                                                }
                                                                else
                                                                {
                                                                    <button type="button" class="btn btn-sm btn-outline-danger" disabled><i class="fas fa-times"></i></button>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                                else
                                                {
                                                    <tr class="fila-persona align-middle">
                                                        <td class="text-center"><span class="badge bg-primary numero-fila">1</span></td>
                                                        <td>
                                                            <div class="input-group input-group-sm">
                                                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                                                                <input type="text" class="form-control nombre-input" name="NombresPersonas[0]" placeholder="Tu nombre completo" required maxlength="100" />
                                                            </div>
                                                        </td>
                                                        <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger" disabled><i class="fas fa-times"></i></button></td>
                                                    </tr>
                                                }
                                            </tbody>
                                            <tfoot class="table-secondary">
                                                <tr>
                                                    <td colspan="3" class="text-end py-2">
                                                        <strong class="text-dark">Total de Personas: <span class="badge bg-success" id="total-personas">@(Model.NombresPersonas?.Count ?? 1)</span></strong>
                                                    </td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <hr />

                <!-- ========== BOTONES ========== -->
                <div class="d-flex gap-2">
                    <button type="submit" id="btnEditarSolicitud" class="btn btn-warning">
                        <i class="fas fa-save me-1"></i> Actualizar Borrador
                    </button>
                    <button type="button" id="btnEnviarAprobacion" class="btn btn-success" onclick="enviarAprobacion(@Model.Id)">
                        <i class="fas fa-paper-plane me-1"></i> Enviar a Aprobación
                    </button>
                    <button type="reset" class="btn btn-outline-secondary">Limpiar</button>
                    <a asp-action="Index" class="btn btn-outline-danger">Cancelar</a>
                </div>

                <!-- Nota informativa -->
                <div class="alert alert-info mt-3">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Nota:</strong>
                    <ul class="mb-0 mt-2">
                        <li><strong>Actualizar Borrador:</strong> Guarda los cambios pero mantiene la solicitud en estado BORRADOR.</li>
                        <li><strong>Enviar a Aprobación:</strong> - Si tienes jefe directo, se enviará a él primero<br> - Si NO tienes jefe directo, se enviará directamente a Finanzas<br> <strong>Una vez enviada, NO podrás editarla.</strong></li>
                    </ul>
                </div>
            }
        </div>
    </div>
</div>

<!-- Formulario oculto para enviar a aprobación -->
<form id="formEnviarAprobacion" asp-action="EnviarAprobacion" method="post" style="display: none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
</form>

