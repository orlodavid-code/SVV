                                    @if (Model.FechaSalida.HasValue)
                                    {
                                        <div>@FormatDateOnly(Model.FechaSalida)</div>
                                        @if (Model.HoraSalida.HasValue)
                                        {
                                            <div class="info-subtext">
                                                <i class="fas fa-clock me-1"></i>
                                                @Model.HoraSalida.Value.ToString(@"hh\:mm") hrs
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="info-subtext">
                                                <i class="fas fa-clock me-1"></i>
                                                <span class="text-muted">Hora no especificada</span>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">No especificada</span>
                                    }
                                </div>
                            </div>

                            <div class="info-row">
                                <div class="info-label">Regreso:</div>
                                <div class="info-value">
                                    @if (Model.FechaRegreso.HasValue)
                                    {
                                        <div>@FormatDateOnly(Model.FechaRegreso)</div>
                                        @if (Model.HoraRegreso.HasValue)
                                        {
                                            <div class="info-subtext">
                                                <i class="fas fa-clock me-1"></i>
                                                @Model.HoraRegreso.Value.ToString(@"hh\:mm") hrs
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="info-subtext">
                                                <i class="fas fa-clock me-1"></i>
                                                <span class="text-muted">Hora no especificada</span>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">No especificada</span>
                                    }
                                </div>
                            </div>

                            @if (Model.FechaSalida.HasValue && Model.FechaRegreso.HasValue)
                            {
