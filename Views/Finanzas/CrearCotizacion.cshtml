                                <div class="info-header-icon">
                                    <i class="fas fa-calendar-alt" style="font-size: 0.7rem; color: var(--viamtek-green);"></i>
                                </div>
                                <div class="info-header-text">Fechas y Horas del Viaje</div>
                            </div>

                            <div class="info-row">
