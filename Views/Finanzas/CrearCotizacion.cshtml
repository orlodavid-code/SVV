                                    <div class="info-label">Duración:</div>
                                    <div class="info-value">
                                        @{
                                            var diasViaje = (Model.FechaRegreso.Value.DayNumber - Model.FechaSalida.Value.DayNumber) + 1;
                                            <text>@diasViaje día(s)</text>
                                        }
                                    </div>
                                </div>
                            }
