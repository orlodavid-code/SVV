                                        <i class="fas fa-taxi" style="font-size: 0.7rem; color: white;"></i>
                                    </div>
                                    <div class="info-header-text">Servicio de Taxi</div>
                                </div>
                                <div class="ruta-item mt-2">
                                    <div class="ruta-icon" style="background: var(--viamtek-green);">
                                        <i class="fas fa-map-marker-alt" style="font-size: 0.6rem; color: white;"></i>
                                    </div>
                                    <div class="ruta-text">
                                        <strong>Origen Taxi:</strong><br />
                                        @if (!string.IsNullOrEmpty(Model.DireccionTaxiOrigen))
                                        {
