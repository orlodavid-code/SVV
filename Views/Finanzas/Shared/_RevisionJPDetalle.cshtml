@model SVV.Models.ComprobacionesViaje

<div class="detalles-revision-container">
    <div class="row g-3">
        <div class="col-md-6">
            <div class="card-detalle">
                <div class="card-header">
                    <h6><i class="fas fa-info-circle me-2"></i>Información General</h6>
                </div>
                <div class="card-body">
                    <table class="table table-detalle">
                        <tr>
                            <th width="40%">Código:</th>
                            <td>
                                <strong class="text-primary">@Model.CodigoComprobacion</strong>
                            </td>
                        </tr>
                        <tr>
                            <th>Empleado:</th>
                            <td>@Model.SolicitudViaje?.Empleado?.Nombre @Model.SolicitudViaje?.Empleado?.Apellidos</td>
                        </tr>
                        <tr>
                            <th>Departamento:</th>
                            <td>@Model.SolicitudViaje?.Empleado?.Departamento</td>
                        </tr>
                        <tr>
                            <th>Proyecto:</th>
                            <td>@Model.SolicitudViaje?.NombreProyecto</td>
                        </tr>
                        <tr>
                            <th>Fecha Viaje:</th>
                            <td>
                                <i class="fas fa-calendar-alt me-1 text-muted"></i>
                                @Model.SolicitudViaje?.FechaSalida.ToString("dd/MM/yyyy") -
                                @Model.SolicitudViaje?.FechaRegreso.ToString("dd/MM/yyyy")
                            </td>
                        </tr>
                        <tr>
                            <th>Anticipo:</th>
                            <td>
                                <i class="fas fa-money-bill-wave me-1 text-muted"></i>
                                @(Model.TotalAnticipo?.ToString("C") ?? "$0.00")
                            </td>
                        </tr>
                        <tr>
                            <th>Total Gastado:</th>
                            <td>
                                <i class="fas fa-receipt me-1 text-muted"></i>
                                @(Model.TotalGastosComprobados?.ToString("C") ?? "$0.00")
                            </td>
                        </tr>
                        <tr>
                            <th>Diferencia:</th>
                            <td>
                                @{
                                    var diferencia = Model.Diferencia ?? 0;
                                    var claseDiferencia = diferencia > 0 ? "diferencia-positiva-detalle diferencia-detalle" :
                                    diferencia < 0 ? "diferencia-negativa-detalle diferencia-detalle" :
                                    "diferencia-cero-detalle diferencia-detalle";
                                }
                                <span class="@claseDiferencia">
                                    @if (diferencia > 0)
                                    {
                                        <i class="fas fa-arrow-up me-1"></i>
                                    }
                                    else if (diferencia < 0)
                                    {
                                        <i class="fas fa-arrow-down me-1"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-equals me-1"></i>
                                    }
                                    @diferencia.ToString("C")
                                </span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card-detalle">
                <div class="card-header">
                    <h6><i class="fas fa-money-bill-wave me-2"></i>Información Financiera</h6>
                </div>
                <div class="card-body">
                    <table class="table table-detalle">
                        <tr>
                            <th width="40%">Escenario:</th>
                            <td>
                                @switch (Model.EscenarioLiquidacion)
                                {
                                    case "REPOSICION_EMPRESA":
                                        <span class="badge escenario-reposicion-empresa">
                                            <i class="fas fa-building me-1"></i>REPOSICIÓN EMPRESA
                                        </span>
                                        break;
                                    case "REPOSICION_COLABORADOR":
                                        <span class="badge escenario-reposicion-colaborador">
                                            <i class="fas fa-user me-1"></i>REPOSICIÓN COLABORADOR
                                        </span>
                                        break;
                                    case "PAGO_AUTORIZADO":
                                        <span class="badge escenario-pago-autorizado">
                                            <i class="fas fa-check-circle me-1"></i>PAGO AUTORIZADO
                                        </span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@Model.EscenarioLiquidacion</span>
                                        break;
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Estado:</th>
                            <td>
                                <span class="badge bg-warning">
                                    <i class="fas fa-clock me-1"></i>@Model.EstadoComprobacion?.Codigo
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th>Fecha Comp.:</th>
                            <td>
                                <i class="fas fa-calendar-check me-1 text-muted"></i>
                                @(Model.FechaComprobacion?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")
                            </td>
                        </tr>
                        <tr>
                            <th>Comentarios:</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.ComentariosFinanzas))
                                {
                                    <div class="contenido-comentarios">
                                        @Html.Raw(Model.ComentariosFinanzas.Replace("\n", "<br>"))
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Sin comentarios</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-12">
            <div class="card-detalle mb-3">
                <div class="card-header">
                    <h6><i class="fas fa-tasks me-2"></i>Actividades Realizadas</h6>
                </div>
                <div class="card-body">
                    <div class="contenido-descripcion">
                        @if (!string.IsNullOrEmpty(Model.DescripcionActividades))
                        {
                            @Html.Raw(Model.DescripcionActividades.Replace("\n", "<br>"))
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="fas fa-clipboard-list fa-2x mb-2"></i>
                                <p>Sin descripción de actividades</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card-detalle mb-3">
                <div class="card-header">
                    <h6><i class="fas fa-chart-line me-2"></i>Resultados del Viaje</h6>
                </div>
                <div class="card-body">
                    <div class="contenido-descripcion">
                        @if (!string.IsNullOrEmpty(Model.ResultadosViaje))
                        {
                            @Html.Raw(Model.ResultadosViaje.Replace("\n", "<br>"))
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="fas fa-chart-bar fa-2x mb-2"></i>
                                <p>Sin resultados reportados</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>