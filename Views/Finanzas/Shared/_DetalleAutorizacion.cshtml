@model SVV.Models.ComprobacionesViaje
@section Styles {
    <link rel="stylesheet" href="~/css/detalle-autorizacion.css" />
}
<div class="detalles-autorizacion">
    <!-- Encabezado -->
    <div class="encabezado-autorizacion">
        <h4>Autorización de Pago/Reintegro</h4>
        <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted">ID: @Model.Id - @Model.CodigoComprobacion</span>
            <span class="badge bg-info">@Model.EstadoComprobacion?.Codigo</span>
        </div>
    </div>

    <!-- Información General -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h6><i class="fas fa-user"></i> Información del Empleado</h6>
                </div>
                <div class="card-body">
                    <table class="table">
                        <tr>
                            <th>Nombre:</th>
                            <td>@Model.SolicitudViaje?.Empleado?.Nombre @Model.SolicitudViaje?.Empleado?.Apellidos</td>
                        </tr>
                        <tr>
                            <th>Departamento:</th>
                            <td>@Model.SolicitudViaje?.Empleado?.Departamento</td>
                        </tr>
                        <tr>
                            <th>Proyecto:</th>
                            <td>@Model.SolicitudViaje?.NombreProyecto</td>
                        </tr>
                        <tr>
                            <th>Solicitud:</th>
                            <td>
                                <a href="@Url.Action("Detalles", "Solicitudes", new { id = Model.SolicitudViajeId })"
                                   target="_blank" class="text-decoration-none">
                                    @Model.SolicitudViaje?.CodigoSolicitud
                                </a>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h6><i class="fas fa-calculator"></i> Resumen Financiero</h6>
                </div>
                <div class="card-body">
                    <table class="table">
                        <tr>
                            <th>Anticipo Otorgado:</th>
                            <td class="text-end">@(Model.TotalAnticipo?.ToString("C") ?? "$0.00")</td>
                        </tr>
                        <tr>
                            <th>Total Gastado:</th>
                            <td class="text-end">@(Model.TotalGastosComprobados?.ToString("C") ?? "$0.00")</td>
                        </tr>
                        <tr class="table-active">
                            <th><strong>Diferencia:</strong></th>
                            <td class="text-end">
                                @{
                                    var diferencia = Model.Diferencia ?? 0;
                                    var claseDiferencia = diferencia > 0 ? "diferencia-positiva-autorizacion" :
                                    diferencia < 0 ? "diferencia-negativa-autorizacion" : "diferencia-cero-autorizacion";
                                }
                                <span class="@claseDiferencia diferencia-autorizacion">
                                    @diferencia.ToString("C")
                                </span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Escenario y Acción -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="escenario-autorizacion-card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-exchange-alt me-2"></i>Escenario de Liquidación</h6>
                </div>
                <div class="card-body">
                    @{
                        var diff = Model.Diferencia ?? 0;
                        var escenario = Model.EscenarioLiquidacion;
                    }

                    @if (escenario == "REPOSICION_EMPRESA")
                    {
                        <div class="alert alert-warning">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-building fa-2x me-3"></i>
                                <div>
                                    <h5 class="alert-heading mb-1">Reposición a Empresa</h5>
                                    <p class="mb-0">El empleado <strong>debe reintegrar</strong> a la empresa.</p>
                                </div>
                            </div>
                        </div>
                    }
                    else if (escenario == "REPOSICION_COLABORADOR")
                    {
                        <div class="alert alert-info">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-user fa-2x me-3"></i>
                                <div>
                                    <h5 class="alert-heading mb-1">Reposición al Colaborador</h5>
                                    <p class="mb-0">La empresa <strong>debe pagar</strong> al empleado.</p>
                                </div>
                            </div>
                        </div>
                    }
                    else if (escenario == "PAGO_AUTORIZADO")
                    {
                        <div class="alert alert-success">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-check-circle fa-2x me-3"></i>
                                <div>
                                    <h5 class="alert-heading mb-1">Pago Autorizado</h5>
                                    <p class="mb-0">La comprobación está lista para cerrar.</p>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Información detallada del escenario -->
                    <div class="row mt-3">
                        <div class="col-md-4">
                            <div class="resumen-escenario-card">
                                <div class="text-muted small">ESCENARIO</div>
                                <div class="fw-bold mt-2">
                                    @switch (escenario)
                                    {
                                        case "REPOSICION_EMPRESA":
                                            <span class="badge bg-warning">REPOSICIÓN EMPRESA</span>
                                            break;
                                        case "REPOSICION_COLABORADOR":
                                            <span class="badge bg-info">REPOSICIÓN COLABORADOR</span>
                                            break;
                                        case "PAGO_AUTORIZADO":
                                            <span class="badge bg-success">PAGO AUTORIZADO</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@escenario</span>
                                            break;
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="resumen-escenario-card">
                                <div class="text-muted small">MONTO</div>
                                <div class="fs-4 fw-bold @(diff > 0 ? "text-success" : diff < 0 ? "text-danger" : "text-secondary")">
                                    @Math.Abs(diff).ToString("C")
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="resumen-escenario-card">
                                <div class="text-muted small">ACCIÓN REQUERIDA</div>
                                <div class="fw-bold">
                                    @if (escenario == "REPOSICION_EMPRESA" && diff > 0)
                                    {
                                        <span class="text-danger">AUTORIZAR REINTEGRO</span>
                                    }
                                    else if (escenario == "REPOSICION_COLABORADOR" && diff < 0)
                                    {
                                        <span class="text-success">AUTORIZAR PAGO</span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary">MARCAR COMO LIQUIDADO</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Botones de acción -->
    <div class="btn-accion-container">
        <div class="d-flex justify-content-center gap-4">
            @if (escenario == "REPOSICION_EMPRESA" && diff > 0)
            {
                <button class="btn-accion btn-warning"
                        data-accion="REINTEGRO"
                        data-monto="@Math.Abs(diff)">
                    <i class="fas fa-arrow-left"></i>
                    Autorizar Reintegro
                    <span class="small">(Colaborador → Empresa)</span>
                </button>
            }
            else if (escenario == "REPOSICION_COLABORADOR" && diff < 0)
            {
                <button class="btn-accion btn-success"
                        data-accion="PAGO"
                        data-monto="@Math.Abs(diff)">
                    <i class="fas fa-arrow-right"></i>
                    Autorizar Pago
                    <span class="small">(Empresa → Colaborador)</span>
                </button>
            }
            else if (escenario == "PAGO_AUTORIZADO")
            {
                <button class="btn-accion btn-secondary"
                        data-accion="LIQUIDADO">
                    <i class="fas fa-check-circle"></i>
                    Marcar como Liquidado
                    <span class="small">Sin movimientos financieros</span>
                </button>
            }
            else
            {
                <button class="btn-accion btn-secondary"
                        data-accion="LIQUIDADO">
                    <i class="fas fa-check-circle"></i>
                    Marcar como Liquidado
                    <span class="small">Sin movimientos financieros</span>
                </button>
            }

            <button class="btn-accion btn-outline-secondary" data-accion="CANCELAR">
                <i class="fas fa-times"></i>
                Cancelar
                <span class="small">Cerrar sin cambios</span>
            </button>
        </div>

        <div class="nota-autorizacion mt-4">
            <i class="fas fa-info-circle me-1"></i>
            Esta acción cambiará el estado a "SALDADA" y generará el registro correspondiente en el sistema.
        </div>
    </div>
