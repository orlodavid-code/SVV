                                                    <th>Precio Individual</th>
                                                    <th>Descripción (opcional)</th>
                                                    <th width="80">Acciones</th>
                                                </tr>
                                            </thead>
                                            <tbody id="alimentos-body">
                                                @for (int i = 0; i < Model.AlimentosPrecios.Count; i++)
                                                {
                                                    <tr class="fila-precio">
                                                        <td class="numero-fila">@(i + 1)</td>
                                                        <td>
                                                            <div class="input-group input-group-sm">
                                                                <span class="input-group-text">$</span>
                                                                <input asp-for="AlimentosPrecios[i].Precio"
                                                                       class="form-control precio-input"
                                                                       type="text"
                                                                       inputmode="decimal"
                                                                       data-concepto="alimentos"
                                                                       value="@FormatDecimal(Model.AlimentosPrecios[i].Precio)" />
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <input asp-for="AlimentosPrecios[i].Descripcion"
                                                                   class="form-control form-control-sm descripcion-input"
                                                                   placeholder="Ej: Comida día 1"
                                                                   value="@Model.AlimentosPrecios[i].Descripcion" />
                                                        </td>
                                                        <td>
                                                            <button type="button" class="btn btn-danger btn-sm btn-eliminar-precio"
                                                                    onclick="eliminarFila(this)"
                                                                    @(Model.AlimentosPrecios.Count <= 1 ? "disabled" : "")>
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                            <tfoot>
                                                <tr class="total-concepto">
                                                    <td colspan="4" class="text-end">
                                                        <strong>Subtotal Alimentos: $<span class="subtotal" data-concepto="alimentos">@FormatDecimal(Model.TotalAlimentos)</span></strong>
                                                    </td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <div class="total-card">
                                <div class="text-secondary-label mb-2">TOTAL AUTORIZADO</div>
                                <div class="total-glow">
                                    <span id="total-display">$@FormatDecimal(Model.Total)</span>
                                </div>
                                <div class="text-secondary-label mt-2">Monto asignado como anticipo de viáticos</div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label text-secondary-label d-flex align-items-center mb-2">
                                    <span class="icon-circle" style="width: 35px; height: 35px; margin-right: 12px;">
                                        <i class="fas fa-sticky-note"></i>
                                    </span>
                                    Observaciones
                                </label>
                                <textarea asp-for="Observaciones" class="form-control textarea-rounded" rows="3"
                                          placeholder="Notas adicionales sobre la cotización...">@Model.Observaciones</textarea>
                                <span asp-validation-for="Observaciones" class="text-danger small"></span>
                            </div>

                            <div class="d-flex gap-3 justify-content-end">
                                <a asp-action="Cotizaciones" class="btn btn-secondary d-flex align-items-center">
                                    <i class="fas fa-arrow-left me-2"></i>Cancelar
                                </a>
                                <button type="submit" class="btn btn-primary d-flex align-items-center" id="btnActualizar">
                                    <i class="fas fa-save me-2"></i>Actualizar Cotización
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/cotizaciones-calculo.js"></script>
    <script>
        // SISTEMA DE GESTIÓN DE NOMBRES PARA MODEL BINDING
        function capitalizeFirst(string) {
            return string.charAt(0).toUpperCase() + string.slice(1);
        }

        // SINCRONIZACIÓN DE CAMPOS OCULTOS DE CANTIDAD
        function actualizarCampoCantidadHidden(concepto, valor) {
            const campoId = `${capitalizeFirst(concepto)}Cantidad`;
            const campoHidden = document.getElementById(campoId);
            if (campoHidden) {
                campoHidden.value = valor;
            }
        }

        // INICIALIZACIÓN DE CAMPOS DESDE EL MODELO RAZOR
        function inicializarCamposCantidad() {
            document.getElementById('TransporteCantidad').value = @Model.TransporteCantidad;
            document.getElementById('GasolinaCantidad').value = @Model.GasolinaCantidad;
            document.getElementById('UberTaxiCantidad').value = @Model.UberTaxiCantidad;
            document.getElementById('CasetasCantidad').value = @Model.CasetasCantidad;
            document.getElementById('HospedajeCantidad').value = @Model.HospedajeCantidad;
            document.getElementById('AlimentosCantidad').value = @Model.AlimentosCantidad;
        }

        // ============================================
        // VALIDACIÓN DE CANTIDAD DE PRECIOS (MÁXIMO 30)
        // ============================================

        function validarCantidadPrecios(input) {
            if (!input || !input.value) return;

            // Solo permitir números enteros
            let valor = input.value.replace(/\D/g, '');

            if (valor === '') {
                input.value = '';
                return;
            }

            // Convertir a número
            let numero = parseInt(valor, 10);

            // Mínimo 1
            if (numero < 1) numero = 1;

            // Máximo 30 - ¡ESTA ES LA VALIDACIÓN QUE PIDES!
            if (numero > 30) {
                numero = 30;
                mostrarErrorCantidadPrecios(input, 'No se permiten más de 30 precios por concepto.');
            } else {
                limpiarErrorCantidadPrecios(input);
            }

            // Actualizar valor
            input.value = numero;

            // Disparar actualización de filas
            actualizarFilasPorCantidad(input);
        }

        function mostrarErrorCantidadPrecios(input, mensaje) {
            // Limpiar error anterior
            limpiarErrorCantidadPrecios(input);

            // Crear elemento de error
            const errorElement = document.createElement('div');
            errorElement.className = 'text-danger small mt-1 error-cantidad';
            errorElement.textContent = mensaje;
            errorElement.id = `error-${input.id || input.name}`;

            // Insertar después del input
            input.parentNode.appendChild(errorElement);

            // Estilo visual
            input.classList.add('is-invalid');
        }

        function limpiarErrorCantidadPrecios(input) {
            const errorId = `error-${input.id || input.name}`;
            const errorElement = document.getElementById(errorId);
            if (errorElement) {
                errorElement.remove();
            }
            input.classList.remove('is-invalid');
        }

        // ============================================
        // VALIDACIÓN DE PRECIOS CON 2 DECIMALES - CORREGIDA
        // ============================================

        function manejarEntradaPrecio(input) {
            if (!input) return;

            // Guardar la posición del cursor
            const inicio = input.selectionStart;
            const fin = input.selectionEnd;

            // Obtener el valor actual
            let valor = input.value;

            // Permitir números, un solo punto decimal y comas
            valor = valor.replace(/,/g, '.');

            // Eliminar caracteres no válidos excepto números y punto
            valor = valor.replace(/[^\d.]/g, '');

            // Si hay más de un punto, mantener solo el primero
            const partes = valor.split('.');
            if (partes.length > 2) {
                valor = partes[0] + '.' + partes.slice(1).join('');
            }

            // Limitar a 2 decimales después del punto
            if (valor.includes('.')) {
                const [entero, decimal] = valor.split('.');
                if (decimal.length > 2) {
                    valor = entero + '.' + decimal.substring(0, 2);
                }
            }

            // Si el valor empieza con punto, agregar 0 antes
            if (valor.startsWith('.')) {
                valor = '0' + valor;
            }

            // Actualizar el valor del input
            input.value = valor;

            // Restaurar posición del cursor
            input.setSelectionRange(inicio, fin);

            // Recalcular totales
            recalcularTotales();
        }

        function formatearPrecioAlPerderFoco(input) {
            if (!input || !input.value) {
                input.classList.remove('is-valid', 'is-invalid');
                return;
            }

            const valor = input.value.replace(/,/g, '.');
            const numero = parseFloat(valor);

            if (!isNaN(numero) && numero >= 0) {
                // Formatear con 2 decimales
                input.value = numero.toFixed(2);
                input.classList.add('is-valid');
                input.classList.remove('is-invalid');
            } else {
                input.classList.add('is-invalid');
                input.classList.remove('is-valid');
            }

            // Recalcular totales
            recalcularTotales();
        }

        // Función auxiliar para formatear siempre a 2 decimales
        function formatearADosDecimales(numero) {
            if (!numero && numero !== 0) return '0.00';

            const num = parseFloat(numero);
            if (isNaN(num)) return '0.00';

            return num.toFixed(2);
        }

        // GESTIÓN DINÁMICA DE FILAS POR CONCEPTO
        function actualizarFilasPorCantidad(inputElement) {
            const concepto = inputElement.dataset.concepto;
            const cantidad = parseInt(inputElement.value) || 1;
            const cuerpoId = `${concepto}-body`;
            const tbody = document.getElementById(cuerpoId);

            if (!tbody) return;

            const filasActuales = tbody.querySelectorAll('tr.fila-precio');
            const cantidadActual = filasActuales.length;

            if (cantidad > cantidadActual) {
                for (let i = cantidadActual; i < cantidad; i++) {
                    const nuevaFila = crearFilaPrecio(concepto, i + 1, 0, '');
                    tbody.appendChild(nuevaFila);
                }
            }
            else if (cantidad < cantidadActual) {
                for (let i = cantidadActual - 1; i >= cantidad; i--) {
                    tbody.removeChild(filasActuales[i]);
                }
            }

            const nuevasFilas = tbody.querySelectorAll('tr.fila-precio');
            const nombrePropiedad = capitalizeFirst(concepto) + 'Precios';

            nuevasFilas.forEach((fila, index) => {
                fila.querySelector('.numero-fila').textContent = index + 1;

                const precioInput = fila.querySelector('.precio-input');
                const descripcionInput = fila.querySelector('.descripcion-input');

                if (precioInput) {
                    precioInput.name = `${nombrePropiedad}[${index}].Precio`;
                }
                if (descripcionInput) {
                    descripcionInput.name = `${nombrePropiedad}[${index}].Descripcion`;
                }
            });

            actualizarCampoCantidadHidden(concepto, cantidad);
            recalcularTotales();
        }

        // AGREGAR FILA MANUALMENTE
        function agregarFilaManual(concepto) {
            const cuerpoId = `${concepto}-body`;
            const tbody = document.getElementById(cuerpoId);
            const cantidadInput = document.querySelector(`.cantidad-input[data-concepto="${concepto}"]`);

            if (!tbody || !cantidadInput) return;

            // Validar antes de agregar
            const nuevaCantidad = (parseInt(cantidadInput.value) || 0) + 1;

            // ¡VALIDAR MÁXIMO 30!
            if (nuevaCantidad > 30) {
                mostrarErrorCantidadPrecios(cantidadInput, 'No se permiten más de 30 precios por concepto.');
                return;
            }

            cantidadInput.value = nuevaCantidad;

            actualizarCampoCantidadHidden(concepto, nuevaCantidad);

            const numeroFila = tbody.querySelectorAll('tr.fila-precio').length + 1;
            const nuevaFila = crearFilaPrecio(concepto, numeroFila, 0, '');
            tbody.appendChild(nuevaFila);

            recalcularTotales();
        }

        // ELIMINAR FILA CON REINDEXACIÓN AUTOMÁTICA
        function eliminarFila(boton) {
            const fila = boton.closest('tr.fila-precio');
            const precioInput = fila.querySelector('.precio-input');
            if (!precioInput) return;

            const concepto = precioInput.dataset.concepto;
            const cantidadInput = document.querySelector(`.cantidad-input[data-concepto="${concepto}"]`);

            if (cantidadInput && parseInt(cantidadInput.value) > 1) {
                fila.remove();
                const nuevaCantidad = parseInt(cantidadInput.value) - 1;
                cantidadInput.value = nuevaCantidad;

                actualizarCampoCantidadHidden(concepto, nuevaCantidad);

                const tbody = document.getElementById(`${concepto}-body`);
                const filas = tbody.querySelectorAll('tr.fila-precio');
                const nombrePropiedad = capitalizeFirst(concepto) + 'Precios';

                filas.forEach((fila, index) => {
                    fila.querySelector('.numero-fila').textContent = index + 1;

                    const precioInput = fila.querySelector('.precio-input');
                    const descripcionInput = fila.querySelector('.descripcion-input');

                    if (precioInput) {
                        precioInput.name = `${nombrePropiedad}[${index}].Precio`;
                    }
                    if (descripcionInput) {
                        descripcionInput.name = `${nombrePropiedad}[${index}].Descripcion`;
                    }
                });

                recalcularTotales();
            }
        }

        // CREACIÓN DE FILAS DE PRECIO CON MODEL BINDING CORRECTO
        function crearFilaPrecio(concepto, numero, precio = 0, descripcion = '') {
            const tr = document.createElement('tr');
            tr.className = 'fila-precio';

            const tbody = document.getElementById(`${concepto}-body`);
            const indice = tbody ? tbody.querySelectorAll('tr.fila-precio').length : numero - 1;
            const nombrePropiedad = capitalizeFirst(concepto) + 'Precios';

            tr.innerHTML = `
                <td class="numero-fila">${numero}</td>
                <td>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">$</span>
                        <input class="form-control precio-input"
                               type="text"
                               inputmode="decimal"
                               value="${formatearADosDecimales(precio)}"
                               data-concepto="${concepto}"
                               name="${nombrePropiedad}[${indice}].Precio" />
                    </div>
                </td>
                <td>
                    <input class="form-control form-control-sm descripcion-input"
                           placeholder="Descripción (opcional)"
                           type="text"
                           name="${nombrePropiedad}[${indice}].Descripcion"
                           value="${descripcion}" />
                </td>
                <td>
                    <button type="button" class="btn btn-danger btn-sm btn-eliminar-precio" onclick="eliminarFila(this)">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            `;

            // Agregar eventos al input de precio recién creado
            const precioInput = tr.querySelector('.precio-input');
            if (precioInput) {
                precioInput.addEventListener('input', function() {
                    manejarEntradaPrecio(this);
                });

                precioInput.addEventListener('blur', function() {
                    formatearPrecioAlPerderFoco(this);
                });

                // Validación de teclas para permitir solo números y punto
                precioInput.addEventListener('keydown', function(e) {
                    // Permitir teclas de navegación, borrado, tab, etc.
                    const teclasPermitidas = [8, 9, 13, 37, 38, 39, 40, 46]; // backspace, tab, enter, flechas, delete
                    if (teclasPermitidas.includes(e.keyCode)) {
                        return;
                    }

                    // Permitir números (teclado principal y numérico)
                    if ((e.keyCode >= 48 && e.keyCode <= 57) || // números 0-9
                        (e.keyCode >= 96 && e.keyCode <= 105)) { // teclado numérico
                        return;
                    }

                    // Permitir punto (190) y coma (188) - pero convertiremos comas a puntos
                    if (e.keyCode === 190 || e.keyCode === 110 || e.keyCode === 188) {
                        return;
                    }

                    // Bloquear cualquier otra tecla
                    e.preventDefault();
                });
            }

            return tr;
        }

        // FUNCIÓN PARA RECALCULAR TOTALES (AJUSTADA PARA MANEJAR DECIMALES)
        function recalcularTotales() {
            const conceptos = ['transporte', 'gasolina', 'ubertaxi', 'casetas', 'hospedaje', 'alimentos'];
            let totalGeneral = 0;

            conceptos.forEach(concepto => {
                const tbody = document.getElementById(`${concepto}-body`);
                if (!tbody) return;

                const filas = tbody.querySelectorAll('tr.fila-precio');
                let subtotal = 0;

                filas.forEach(fila => {
                    const precioInput = fila.querySelector('.precio-input');
                    if (precioInput && precioInput.value) {
                        // Parsear asegurando 2 decimales
                        const precio = parseFloat(precioInput.value.replace(/,/g, '.')) || 0;
                        subtotal += precio;
                    }
                });

                // Actualizar subtotal en la tabla
                const subtotalElement = document.querySelector(`.subtotal[data-concepto="${concepto}"]`);
                if (subtotalElement) {
                    subtotalElement.textContent = subtotal.toFixed(2);
                }

                // Actualizar campo oculto
                const campoTotalId = `Total${capitalizeFirst(concepto)}`;
                const campoTotal = document.getElementById(campoTotalId);
                if (campoTotal) {
                    campoTotal.value = subtotal.toFixed(2);
                }

                totalGeneral += subtotal;
            });

            // Actualizar total general
            const totalDisplay = document.getElementById('total-display');
            if (totalDisplay) {
                totalDisplay.textContent = `$${totalGeneral.toFixed(2)}`;
            }

            const totalGeneralInput = document.getElementById('TotalGeneral');
            if (totalGeneralInput) {
                totalGeneralInput.value = totalGeneral.toFixed(2);
            }
        }

        // CONFIGURACIÓN INICIAL DEL SISTEMA
        document.addEventListener('DOMContentLoaded', function() {
            inicializarCamposCantidad();

            if (window.calculoManager) {
                const originalAplicarDetalleConcepto = calculoManager.aplicarDetalleConcepto;
                calculoManager.aplicarDetalleConcepto = async function(tipo, detalles) {
                    await originalAplicarDetalleConcepto.call(this, tipo, detalles);
                    actualizarCampoCantidadHidden(tipo, detalles.length);
                };

                const originalAplicarPrecioIndividual = calculoManager.aplicarPrecioIndividual;
                calculoManager.aplicarPrecioIndividual = async function(tipo, precio, descripcion) {
                    await originalAplicarPrecioIndividual.call(this, tipo, precio, descripcion);
                    actualizarCampoCantidadHidden(tipo, 1);
                };

                const originalAplicarPreciosConcepto = calculoManager.aplicarPreciosConcepto;
                calculoManager.aplicarPreciosConcepto = async function(tipo, precioTotal, numeroPersonas, nombreConcepto) {
                    await originalAplicarPreciosConcepto.call(this, tipo, precioTotal, numeroPersonas, nombreConcepto);
                    actualizarCampoCantidadHidden(tipo, numeroPersonas);
                };
            }

            // CONFIGURACIÓN DE CAMPOS OCULTOS DESDE EL MODELO
            document.getElementById('UsarCalculoAutomatico').value = @Model.UsarCalculoAutomatico.ToString().ToLower();
            document.getElementById('UbicacionBase').value = '@Model.UbicacionBase';
            document.getElementById('Destino').value = '@Model.Destino';
            document.getElementById('FechaSalida').value = '@(Model.FechaSalida?.ToString("yyyy-MM-dd") ?? "")';
            document.getElementById('FechaRegreso').value = '@(Model.FechaRegreso?.ToString("yyyy-MM-dd") ?? "")';
            document.getElementById('HoraSalida').value = '@Model.HoraSalida?.ToString(@"hh\:mm\:ss")';
            document.getElementById('HoraRegreso').value = '@Model.HoraRegreso?.ToString(@"hh\:mm\:ss")';
            document.getElementById('NumeroPersonas').value = @Model.NumeroPersonas;
            document.getElementById('RequiereHospedaje').value = @Model.RequiereHospedaje.ToString().ToLower();
            document.getElementById('NochesHospedaje').value = @Model.NochesHospedaje;
            document.getElementById('MedioTraslado').value = '@Model.MedioTraslado';
            document.getElementById('RequiereTaxiDomicilio').value = @Model.RequiereTaxiDomicilio.ToString().ToLower();
            document.getElementById('DireccionTaxiOrigen').value = '@Model.DireccionTaxiOrigen';
            document.getElementById('DireccionTaxiDestino').value = '@Model.DireccionTaxiDestino';
            document.getElementById('DistanciaCalculada').value = '@Model.DistanciaCalculada';
            document.getElementById('CalculoRealizado').value = @Model.CalculoRealizado.ToString().ToLower();
            document.getElementById('MensajeCalculo').value = '@Model.MensajeCalculo';

            // CONFIGURACIÓN DEL SWITCH DE CÁLCULO AUTOMÁTICO
            const switchCalculo = document.getElementById('usarCalculoAutomatico');
            const hiddenCalculoField = document.getElementById('UsarCalculoAutomatico');
            const btnCalcularAuto = document.getElementById('btnCalcularAuto');

            if (switchCalculo && hiddenCalculoField && btnCalcularAuto) {
                hiddenCalculoField.value = switchCalculo.checked ? 'true' : 'false';
                btnCalcularAuto.disabled = !switchCalculo.checked;

                switchCalculo.addEventListener('change', function() {
                    hiddenCalculoField.value = this.checked ? 'true' : 'false';
                    btnCalcularAuto.disabled = !this.checked;
                });
            }

            // CARGA DE ALERTAS Y ERRORES DESDE EL MODELO
            const alertasJson = document.getElementById('AlertasJson')?.value;
            const erroresJson = document.getElementById('ErroresJson')?.value;

            if (alertasJson && alertasJson !== '[]') {
                try {
                    const alertas = JSON.parse(alertasJson);
                    const alertasDiv = document.getElementById('alertasCalculo');
                    if (alertasDiv && alertas.length > 0) {
                        alertas.forEach(alerta => {
                            const alertaDiv = document.createElement('div');
                            alertaDiv.className = 'alerta-item';
                            alertaDiv.innerHTML = `<i class="fas fa-exclamation-triangle"></i> ${alerta}`;
                            alertasDiv.appendChild(alertaDiv);
                        });
                    }
                } catch (e) {
                    console.error('Error al parsear alertas:', e);
                }
            }

            if (erroresJson && erroresJson !== '[]') {
                try {
                    const errores = JSON.parse(erroresJson);
                    const erroresDiv = document.getElementById('erroresCalculo');
                    if (erroresDiv && errores.length > 0) {
                        errores.forEach(error => {
                            const errorDiv = document.createElement('div');
                            errorDiv.className = 'error-item';
                            errorDiv.innerHTML = `<i class="fas fa-times-circle"></i> ${error}`;
                            erroresDiv.appendChild(errorDiv);
                        });
                    }
                } catch (e) {
                    console.error('Error al parsear errores:', e);
                }
            }

            // INICIALIZACIÓN DE VALIDACIÓN PARA INPUTS EXISTENTES
            // Validación en los inputs de cantidad existentes
            document.querySelectorAll('.cantidad-input').forEach(input => {
                // Asegurar que no excedan 30
                let valor = parseInt(input.value) || 1;
                if (valor > 30) {
                    input.value = 30;
                    mostrarErrorCantidadPrecios(input, 'Se ajustó a 30 precios (máximo permitido).');
                }

                // Agregar evento input
                input.addEventListener('input', function() {
                    validarCantidadPrecios(this);
                });
            });

            // Agregar eventos a los inputs de precio existentes
            document.querySelectorAll('.precio-input').forEach(input => {
                // Remover el evento oninput anterior si existe
                input.removeAttribute('oninput');

                // Agregar nuevos eventos
                input.addEventListener('input', function() {
                    manejarEntradaPrecio(this);
                });

                input.addEventListener('blur', function() {
                    formatearPrecioAlPerderFoco(this);
                });

                // Validación de teclas para permitir solo números y punto
                input.addEventListener('keydown', function(e) {
                    // Permitir teclas de navegación, borrado, tab, etc.
                    const teclasPermitidas = [8, 9, 13, 37, 38, 39, 40, 46]; // backspace, tab, enter, flechas, delete
                    if (teclasPermitidas.includes(e.keyCode)) {
                        return;
                    }

                    // Permitir números (teclado principal y numérico)
                    if ((e.keyCode >= 48 && e.keyCode <= 57) || // números 0-9
                        (e.keyCode >= 96 && e.keyCode <= 105)) { // teclado numérico
                        return;
                    }

                    // Permitir punto (190) y coma (188) - pero convertiremos comas a puntos
                    if (e.keyCode === 190 || e.keyCode === 110 || e.keyCode === 188) {
                        return;
                    }

                    // Bloquear cualquier otra tecla
                    e.preventDefault();
                });
            });

            // VALIDACIÓN FINAL ANTES DE ENVIAR EL FORMULARIO
            const cotizacionForm = document.getElementById('cotizacionForm');
            if (cotizacionForm) {
                cotizacionForm.addEventListener('submit', function(e) {
                    const conceptos = ['transporte', 'gasolina', 'ubertaxi', 'casetas', 'hospedaje', 'alimentos'];

                    conceptos.forEach(concepto => {
                        const cantidadInput = document.querySelector(`.cantidad-input[data-concepto="${concepto}"]`);
                        const campoHidden = document.getElementById(`${capitalizeFirst(concepto)}Cantidad`);

                        if (cantidadInput && campoHidden) {
                            campoHidden.value = cantidadInput.value || 0;
                        }
                    });
                });
            }
        });
    </script>
}