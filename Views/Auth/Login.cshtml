@{
    Layout = null;

    // CONFIGURACIÓN DE HEADERS ANTI-CACHÉ PARA SEGURIDAD
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VIAMTEK - Iniciar Sesión</title>

    <!-- CONFIGURACIÓN META PARA PREVENIR CACHÉ EN CLIENTE -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <!-- FONDO DE VIDEO PARA MEJORAR EXPERIENCIA DE USUARIO -->
    <div class="video-background">
        <video autoplay muted loop id="myVideo">
            <source src="~/videos/b1.mp4" type="video/mp4">
            Tu navegador no soporta el video.
        </video>
        <div class="video-overlay"></div>
    </div>

    <!-- CONTENEDOR PRINCIPAL DEL FORMULARIO DE LOGIN -->
    <div class="login-container">
        <div class="login-box">

            <!-- PANEL DE BIENVENIDA Y LOGO -->
            <div class="welcome-panel">
                <div class="logo-area">
                    <img src="~/images/LOGO1.png" alt="VIAMTEK Logo" class="logo">
                </div>

                <div class="welcome-section text-center">
                    <h1 class="welcome-title">SISTEMA VIÁTICOS VIAMTEK</h1>
                    <p class="welcome-subtitle">Gestión simplificada para tus viajes de negocio.</p>
                </div>
            </div>

            <!-- PANEL DEL FORMULARIO CON VALIDACIONES -->
            <div class="form-panel">
                <h2 class="login-title mb-4">Iniciar Sesión</h2>

                <form method="post" asp-controller="Auth" asp-action="Login" class="login-form" id="loginForm">
                    <!-- SISTEMA DE ALERTAS DESDE EL CONTROLADOR -->
                    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            @ViewBag.ErrorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(ViewBag.SuccessMessage))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>
                            @ViewBag.SuccessMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- CAMPO DE USUARIO CON VALIDACIÓN -->
                    <div class="form-group mb-3">
                        <label for="email" class="form-label">Correo Electrónico o Número de Empleado</label>
                        <div class="input-group transparent-input">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                            <input type="text"
                                   class="form-control"
                                   id="email"
                                   name="email"
                                   required
                                   placeholder="Ingresa tu correo o número"
                                   autocomplete="off">
                        </div>
                    </div>

                    <!-- CAMPO DE CONTRASEÑA CON VISUALIZACIÓN TOGGLE -->
                    <div class="form-group mb-3">
                        <label for="password" class="form-label">Contraseña</label>
                        <div class="input-group transparent-input">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input type="password"
                                   class="form-control"
                                   id="password"
                                   name="password"
                                   required
                                   placeholder="Ingresa tu contraseña"
                                   autocomplete="off">
                            <button type="button" class="btn btn-outline-secondary toggle-password-btn" id="togglePassword">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <!-- OPCIÓN DE RECORDAR SESIÓN -->
                    <div class="d-flex justify-content-between align-items-center mb-4 text-white">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label" for="rememberMe">
                                Recordarme
                            </label>
                        </div>
                    </div>

                    <!-- BOTÓN DE ENVÍO DEL FORMULARIO -->
                    <button type="submit" class="btn btn-primary btn-login w-100" id="btnLogin">
                        INGRESAR
                    </button>
                </form>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SISTEMA DE SEGURIDAD ANTI-CACHÉ Y PROTECCIÓN DE SESIÓN -->
    <script>
        // FUNCIÓN DE INICIALIZACIÓN PARA LIMPIAR SESIONES PREVIAS
        (function() {
            console.log("Inicializando sistema de login - Verificando sesión activa...");

            // DETECCIÓN DE SESIÓN ACTIVA PARA REDIRECCIÓN AUTOMÁTICA
            if (document.cookie.includes('SistemaViaticos.Auth')) {
                console.log("Sesión activa detectada - Redirigiendo al dashboard");
                window.location.href = '/Home/Index';
                return;
            }

            // LIMPIEZA DE ALMACENAMIENTO LOCAL POR SEGURIDAD
            try {
                if (typeof(Storage) !== "undefined") {
                    localStorage.clear();
                    sessionStorage.clear();
                    console.log("Almacenamiento local limpiado correctamente");
                }
            } catch (e) {
                console.warn("No se pudo limpiar el almacenamiento local:", e);
            }

            // PREVENIR CARGA DESDE CACHÉ DEL NAVEGADOR
            window.addEventListener('pageshow', function(event) {
                if (event.persisted) {
                    console.log("Página cargada desde caché - Forzando recarga");
                    window.location.reload();
                }
            });

            // PROTECCIÓN CONTRA NAVEGACIÓN CON BOTÓN ATRÁS
            if (window.history && window.history.pushState) {
                window.history.pushState(null, null, window.location.href);
                window.addEventListener('popstate', function() {
                    window.history.pushState(null, null, window.location.href);
                });
            }

            console.log("Sistema de seguridad de login inicializado");
        })();

        // MANEJO DE ENVÍO DE FORMULARIO CON PREVENCIÓN DE DOBLE CLICK
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            const btnLogin = document.getElementById('btnLogin');

            // VALIDACIÓN DE DOBLE ENVÍO
            if (btnLogin.disabled) {
                e.preventDefault();
                return false;
            }

            // DESHABILITAR BOTÓN DURANTE PROCESO
            btnLogin.disabled = true;
            btnLogin.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Ingresando...';

            // REHABILITACIÓN TEMPORIZADA EN CASO DE ERROR
            setTimeout(function() {
                btnLogin.disabled = false;
                btnLogin.innerHTML = 'INGRESAR';
            }, 3000);
        });
    </script>

    <script src="~/js/login.js" asp-append-version="true"></script>
</body>
</html>