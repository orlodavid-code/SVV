@model SVV.Models.Empleados

@{
    ViewData["Title"] = "Mi Perfil";
}

<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

<div class="container-fluid">
    <!-- CABECERA DINÁMICA -->
    <div class="admin-header">
        <h1 class="admin-title"><i class="fas fa-user-circle me-2"></i> Mi Perfil de Empleado</h1>
        <p class="admin-subtitle">Consulta y verifica toda tu información personal y laboral dentro del sistema.</p>
    </div>

    <div class="row">
        <div class="col-12">
            <!-- TARJETA PRINCIPAL CON ESTILO DINÁMICO -->
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5 class="card-title"><i class="fas fa-id-card-alt me-2"></i> Información Completa</h5>
                    <a asp-action="CambiarPassword" class="btn btn-gradient">
                        <i class="fas fa-key me-1"></i> Cambiar Contraseña
                    </a>
                </div>
                <div class="admin-card-body">
                    <div class="row">
                        <!-- COLUMNA 1: INFORMACIÓN PERSONAL Y CONTACTO -->
                        <div class="col-lg-6 mb-4 mb-lg-0 profile-info-separator">
                            <h6 class="text-white mb-3">
                                <i class="fas fa-user me-2 text-success"></i> Datos Personales y Contacto
                            </h6>
                            <dl class="row profile-dl">
                                <dt class="col-sm-4">Nombre Completo:</dt>
                                <dd class="col-sm-8">@Model.Nombre @Model.Apellidos</dd>

                                <dt class="col-sm-4">Email:</dt>
                                <dd class="col-sm-8">@Model.Email</dd>

                                <dt class="col-sm-4">Teléfono:</dt>
                                <dd class="col-sm-8">@(Model.Telefono ?? "No especificado")</dd>

                                <dt class="col-sm-4">Colaborador Remoto:</dt>
                                <dd class="col-sm-8">
                                    @if (Model.ColaboradorRemoto == true)
                                    {
                                        <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i> Sí</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary" style="background: rgba(255, 255, 255, 0.1) !important; color: var(--secondary-text) !important;"><i class="fas fa-times-circle me-1"></i> No</span>
                                    }
                                </dd>
                            </dl>
                        </div>

                        <!-- COLUMNA 2: INFORMACIÓN LABORAL Y PUESTO -->
                        <div class="col-lg-6 ps-lg-5">
                            <h6 class="text-white mb-3">
                                <i class="fas fa-briefcase me-2 text-success"></i> Detalles Laborales
                            </h6>
                            <dl class="row profile-dl">
                                <dt class="col-sm-4">Rol en Sistema:</dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-success">@Model.Rol?.Nombre</span>
                                </dd>

                                <dt class="col-sm-4">Puesto:</dt>
                                <dd class="col-sm-8">@(Model.Puesto ?? "No especificado")</dd>

                                <dt class="col-sm-4">Área:</dt>
                                <dd class="col-sm-8">@Model.AreaAdscripcion</dd>

                                <dt class="col-sm-4">Departamento:</dt>
                                <dd class="col-sm-8">@(Model.Departamento ?? "No especificado")</dd>

                                <dt class="col-sm-4">Ubicación Base:</dt>
                                <dd class="col-sm-8">@(Model.UbicacionBase ?? "No especificado")</dd>

                                <dt class="col-sm-4">Fecha Ingreso:</dt>
                                <dd class="col-sm-8">@(Model.FechaIngreso?.ToString("dd/MM/yyyy") ?? "No especificada")</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>