@model SVV.ViewModels.CambiarMiPasswordViewModel

@{
    ViewData["Title"] = "Cambiar Contraseña";
    var successMessage = TempData["Success"] as string;
    var errorMessage = TempData["Error"] as string;
}
<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

<div class="container-fluid">
    <div class="admin-header">
        <h1 class="admin-title"><i class="fas fa-key me-2"></i> Cambiar Contraseña</h1>
        <nav aria-label="breadcrumb" class="breadcrumb-viamtek">
            <ol class="breadcrumb bg-transparent p-0 m-0">
                <li class="breadcrumb-item"><a asp-action="MiPerfil" class="text-decoration-none">Mi Perfil</a></li>
                <li class="breadcrumb-item active">Cambiar Contraseña</li>
            </ol>
        </nav>
    </div>

    @if (ViewBag.EsContraseñaTemporal == true)
    {
        <div class="alert alert-warning">
            <h5><i class="fas fa-exclamation-triangle me-2"></i> Contraseña Temporal Detectada</h5>
            <p class="mb-0">Estás usando una contraseña temporal. Por seguridad, debes cambiarla ahora antes de continuar usando el sistema.</p>
        </div>
    }
    
    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i> @ViewBag.Mensaje
        </div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle me-2"></i> @errorMessage
        </div>
    }

    <div class="admin-card">
        <div class="admin-card-header">
            <h5 class="card-title"><i class="fas fa-lock me-2"></i> Cambiar Contraseña</h5>
        </div>
        <div class="admin-card-body">
            <form asp-action="CambiarPassword" method="post" id="passwordForm">
                @Html.AntiForgeryToken()
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="PasswordActual" class="form-label-custom">Contraseña Actual *</label>
                            <div class="input-group">
                                <input asp-for="PasswordActual" type="password" class="form-control form-control-dark" 
                                       required placeholder="Ingresa tu contraseña actual" />
                                <button type="button" class="btn btn-outline-secondary toggle-password" data-target="PasswordActual">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="PasswordActual" class="text-danger"></span>
                            
                            @if (ViewBag.EsContraseñaTemporal == true)
                            {
                                <small class="form-text text-muted">
                                    <i class="fas fa-info-circle me-1"></i>
                                    Tu contraseña actual es la temporal: <strong>Temp123!</strong>
                                </small>
                            }
                        </div>

                        <div class="mb-3">
                            <label asp-for="NuevaPassword" class="form-label-custom">Nueva Contraseña *</label>
                            <div class="input-group">
                                <input asp-for="NuevaPassword" type="password" class="form-control form-control-dark" 
                                       required placeholder="Ingresa tu nueva contraseña" />
                                <button type="button" class="btn btn-outline-secondary toggle-password" data-target="NuevaPassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NuevaPassword" class="text-danger"></span>
                            <small class="form-text text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                La contraseña debe tener al menos 8 caracteres, incluyendo mayúsculas, minúsculas, números y caracteres especiales.
                            </small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmarPassword" class="form-label-custom">Confirmar Nueva Contraseña *</label>
                            <div class="input-group">
                                <input asp-for="ConfirmarPassword" type="password" class="form-control form-control-dark" 
                                       required placeholder="Confirma tu nueva contraseña" />
                                <button type="button" class="btn btn-outline-secondary toggle-password" data-target="ConfirmarPassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmarPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <small class="form-text text-muted mb-2">Fortaleza de la contraseña:</small>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-danger" id="passwordStrengthBar" style="width: 0%"></div>
                            </div>
                            <small id="passwordStrengthText" class="form-text text-muted">Ingresa una contraseña para evaluar</small>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                            <a asp-action="MiPerfil" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-gradient" id="submitBtn">
                                <i class="fas fa-save me-2"></i> Cambiar Contraseña
                            </button>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="alert alert-info h-100">
                            <h5><i class="fas fa-shield-alt me-2"></i> Recomendaciones de Seguridad</h5>
                            <ul class="mb-0">
                                <li>Usa al menos 8 caracteres</li>
                                <li>Incluye letras mayúsculas y minúsculas</li>
                                <li>Agrega al menos un número (0-9)</li>
                                <li>Incluye un carácter especial (@@, #, $, %, etc.)</li>
                                <li>No uses información personal</li>
                                <li>Evita contraseñas comunes</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Mostrar/ocultar contraseña
            document.querySelectorAll('.toggle-password').forEach(function(button) {
                button.addEventListener('click', function() {
                    var targetId = this.getAttribute('data-target');
                    var input = document.querySelector('[name="' + targetId + '"]');
                    var icon = this.querySelector('i');

                    if (input.type === 'password') {
                        input.type = 'text';
                        icon.classList.remove('fa-eye');
                        icon.classList.add('fa-eye-slash');
                    } else {
                        input.type = 'password';
                        icon.classList.remove('fa-eye-slash');
                        icon.classList.add('fa-eye');
                    }
                });
            });

            // Validar fortaleza de contraseña en tiempo real
            var passwordInput = document.querySelector('[name="NuevaPassword"]');
            var strengthBar = document.getElementById('passwordStrengthBar');
            var strengthText = document.getElementById('passwordStrengthText');

            if (passwordInput && strengthBar && strengthText) {
                passwordInput.addEventListener('input', function() {
                    var password = this.value;
                    var strength = 0;
                    var text = '';

                    // Verificar longitud
                    if (password.length >= 8) strength += 25;

                    // Verificar mayúsculas y minúsculas
                    if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength += 25;

                    // Verificar números
                    if (/\d/.test(password)) strength += 25;

                    // Verificar caracteres especiales
                    if (/[^A-Za-z0-9]/.test(password)) strength += 25;

                    // Actualizar barra y texto
                    strengthBar.style.width = strength + '%';

                    if (strength === 0) {
                        strengthBar.className = 'progress-bar bg-danger';
                        text = 'Muy débil';
                    } else if (strength <= 25) {
                        strengthBar.className = 'progress-bar bg-danger';
                        text = 'Débil';
                    } else if (strength <= 50) {
                        strengthBar.className = 'progress-bar bg-warning';
                        text = 'Regular';
                    } else if (strength <= 75) {
                        strengthBar.className = 'progress-bar bg-info';
                        text = 'Buena';
                    } else {
                        strengthBar.className = 'progress-bar bg-success';
                        text = 'Excelente';
                    }

                    strengthText.textContent = text;
                });
            }
        });
    </script>
}